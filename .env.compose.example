# Public URL exposed by the Compose gateway.
SAKUNAGRAPH_PORT=8080
ORIGIN=http://localhost:8080

# Same-origin streaming rollout used by the production frontend.
PUBLIC_ASK_STREAMING_ENABLED=true

# Services running on the Docker host. Replace these with container/service URLs
# if GraphDB or the local model server joins the Compose network.
GRAPHDB_ENDPOINT=http://host.docker.internal:7200/repositories/SakunaGraph
LOCAL_LLM_BASE_URL=http://host.docker.internal:1234
LOCAL_LLM_CHAT_PATH=/api/v1/chat
LOCAL_LLM_MODEL=google/gemma-4-e4b
LOCAL_LLM_TIMEOUT=120
