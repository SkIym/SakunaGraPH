# Leave empty to send browser requests to the same origin (recommended in production).
PUBLIC_API_BASE_URL=

# Development-only Vite proxy target for same-origin /api requests.
API_PROXY_TARGET=http://localhost:8000

# Stage 4 rollout switch. True enables SSE with automatic pre-meta fallback to POST /api/ask.
PUBLIC_ASK_STREAMING_ENABLED=false

# Adapter-node runtime values used behind the Compose gateway. Keep ORIGIN in
# sync with the public URL and do not publish the frontend container directly
# when trusting forwarded headers.
HOST=0.0.0.0
PORT=3000
ORIGIN=http://localhost:8080
HOST_HEADER=x-forwarded-host
PROTOCOL_HEADER=x-forwarded-proto
