{
	"name": "sakunagraph-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"start": "node build",
		"build": "vite build && npm run budget",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --config svelte.config.js --no-tsconfig --fail-on-warnings",
		"lint": "eslint . --max-warnings 0",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:contract": "vitest run tests/contracts",
		"test:contract:live": "python scripts/check_api_contract.py",
		"test:e2e": "playwright test tests/e2e",
		"test:e2e:stream": "playwright test --config playwright.streaming.config.js",
		"test:a11y": "playwright test tests/accessibility",
		"test:performance": "playwright test --config playwright.performance.config.js",
		"test:deployment": "node scripts/check-compose-deployment.js",
		"budget": "node scripts/check-performance-budgets.js",
		"baseline:update": "playwright test tests/visual",
		"quality": "npm run check && npm run lint && npm run format:check && npm run test && npm run build"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"eslint": "^10.7.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.45.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.1.18",
		"vite": "^7.2.6",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@codemirror/language": "^6.0.0",
		"@codemirror/legacy-modes": "^6.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"codemirror": "^6.0.0",
		"d3-color": "^3.1.0",
		"d3-drag": "^3.0.0",
		"d3-force": "^3.0.0",
		"d3-geo": "^3.1.1",
		"d3-hierarchy": "^3.1.2",
		"d3-scale": "^4.0.2",
		"d3-selection": "^3.0.0",
		"d3-zoom": "^3.0.0"
	}
}
