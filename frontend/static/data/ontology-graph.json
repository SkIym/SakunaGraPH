    { "id": "Barangay",                  "label": "Barangay",                    "group": "location",     "definition": "Administrative level 4." },

    { "id": "DisasterType",              "label": "Disaster Type",               "group": "type",         "definition": "Disaster type based on the EM-DAT classification of disasters." },
    { "id": "Source",                    "label": "Source",                      "group": "source",       "definition": "Represents the data source that provided disaster data (NDRRMC, GDA, EM-DAT, DROMIC)." }
