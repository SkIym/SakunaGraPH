{
  "nodes": [
    { "id": "DisasterEvent",             "label": "Disaster Event",              "group": "core",         "definition": "Any event that has dealt notable impact to the population, infrastructure, or has disrupted operations and services." },
    { "id": "MajorEvent",                "label": "Major Event",                 "group": "core",         "definition": "A large-scale or aggregated event spanning days that may encompass multiple locations and related incidents." },
    { "id": "Incident",                  "label": "Incident",                    "group": "core",         "definition": "A localized or small-scale disaster event, often reported at the municipal or barangay level." },

    { "id": "Impact",                    "label": "Impact",                      "group": "impact",       "definition": "Represents the impact of major or incident disasters." },
    { "id": "AffectedPopulation",        "label": "Affected Population",         "group": "impact",       "definition": "Represents affected and displaced persons or families." },
    { "id": "Casualties",                "label": "Casualties",                  "group": "impact",       "definition": "Represents the number of deaths, injured, and missing due to a disaster." },
    { "id": "HousingDamage",             "label": "Housing Damage",              "group": "impact",       "definition": "Represents impact on housing." },
    { "id": "AgricultureDamage",         "label": "Agriculture Damage",          "group": "impact",       "definition": "Represents damage on agriculture, farmers, fisherfolks, and crops." },
    { "id": "InfrastructureDamage",      "label": "Infrastructure Damage",       "group": "impact",       "definition": "Represents impact on infrastructure." },
    { "id": "DamageGeneral",             "label": "Damage (General)",            "group": "impact",       "definition": "Represents general damage not falling under sibling classes." },
    { "id": "AirportDisruption",         "label": "Airport Disruption",          "group": "impact",       "definition": "Represents disruptions on airports." },
    { "id": "FlightDisruption",          "label": "Flight Disruption",           "group": "impact",       "definition": "Represents disruptions on individual flights." },
    { "id": "SeaportDisruption",         "label": "Seaport Disruption",          "group": "impact",       "definition": "Represents seaport disruptions." },
    { "id": "StrandedEvent",             "label": "Stranded Event",              "group": "impact",       "definition": "Represents stranded modes of transportation." },
    { "id": "PowerDisruption",           "label": "Power Disruption",            "group": "impact",       "definition": "Represents power disruptions." },
    { "id": "WaterDisruption",           "label": "Water Disruption",            "group": "impact",       "definition": "Represents clean water disruptions." },
    { "id": "CommunicationLineDisruption","label": "Communication Disruption",   "group": "impact",       "definition": "Represents impact on communication lines." },
    { "id": "ClassSuspension",           "label": "Class Suspension",            "group": "impact",       "definition": "Represents education operational disruptions." },
    { "id": "WorkSuspension",            "label": "Work Suspension",             "group": "impact",       "definition": "Represents work operational disruptions." },
    { "id": "RoadAndBridgesDamage",      "label": "Road & Bridges Damage",       "group": "impact",       "definition": "Represents land transportation disruptions." },

    { "id": "Response",                  "label": "Response",                    "group": "response",     "definition": "Represents the responses taken to a disaster." },
    { "id": "Assistance",                "label": "Assistance",                  "group": "response",     "definition": "Represents the monetary assistance provided during or after a disaster event." },
    { "id": "Relief",                    "label": "Relief",                      "group": "response",     "definition": "Represents relief operations." },
    { "id": "Recovery",                  "label": "Recovery",                    "group": "response",     "definition": "Represents civic repercussions and changes made to recover after the event." },
    { "id": "DeclarationOfCalamity",     "label": "Declaration of Calamity",     "group": "response",     "definition": "Represents events of state of calamity declaration." },

    { "id": "Preparedness",              "label": "Preparedness",                "group": "preparedness", "definition": "Represents preparations done before a disaster event." },
