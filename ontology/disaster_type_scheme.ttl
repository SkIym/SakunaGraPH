@prefix : <https://sakuna.ph/> .
@prefix baw: <https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

:Air a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Transport ;
    skos:definition "Transport accidents involving airplanes, helicopters, airships, and balloons." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Air: Transport accidents involving airplanes, helicopters, airships, and balloons." ;
    skos:prefLabel "Air"@en .

:AnimalAccident a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Biological ;
    skos:definition "Human encounters with dangerous or exotic animals in both urban and rural environments. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Animal accident: Human encounters with dangerous or exotic animals in both urban and rural environments." ;
    skos:prefLabel "Animal Accident"@en .

:ArmedConflict a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Technological ;
    skos:definition "Custom technological or man-made peril class to represent armed conflict events that deal impact to communities" ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Ambush/shooting, grenade/bombing incidents, can also involve civil disturbances, violence, and gun fires or armed scandals that can be due to national and local elections and holidays, for example. Often involves victims, killings, and results to deaths or injury." ;
    skos:prefLabel "Armed Conflict"@en .

:Ashfall a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :VolcanicActivity ;
    skos:definition "Fine (less than 4 mm in diameter) unconsolidated volcanic debris blown into the atmosphere during an eruption; can remain airborne for long periods of time and travel considerable distance from the source.  " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Ashfall: Fine (less than 4 mm in diameter) unconsolidated volcanic debris blown into the atmosphere during an eruption; can remain airborne for long periods of time and travel a considerable distance from the source." ;
    skos:prefLabel "Ashfall"@en .

:AvalancheDry a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementDry ;
    skos:definition "A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Debris Avalanche: The sudden and very rapid downslope movement of a mixed mass of rock and soil. There are two general types of debris avalanches. A cold debris avalanche usually results from an unstable slope suddenly collapsing whereas a hot debris avalanche results from volcanic activity leading to slope instability and collapse." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Avalanche (dry): A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Debris Avalanche: The sudden and very rapid downslope movement of a mixed mass of rock and soil. There are two general types of debris avalanches. A cold debris avalanche usually results from an unstable slope suddenly collapsing whereas a hot debris avalanche results from volcanic activity leading to slope instability and collapse." ;
    skos:prefLabel "Avalanche (Dry)"@en .

:AvalancheWet a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementWet ;
    skos:definition "A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Snow Avalanche: Rapid downslope movement of a mix of snow and ice." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Avalanche (wet): A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Snow Avalanche: Rapid downslope movement of a mix of snow and ice." ;
    skos:prefLabel "Avalanche (Wet)"@en .

:BacterialDisease a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Epidemic ;
    skos:definition "An unusual increase in the number of cases caused by exposure to bacteria either through skin contact, ingestion, or inhalation. Examples include salmonella, Methicillin-Resistant Staphylococcus Aureus (MRSA), and cholera, among others. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Bacterial disease: An unusual increase in the number of cases caused by exposure to bacteria either through skin contact, ingestion, or inhalation. Examples include salmonella, Methicillin-Resistant Staphylococcus Aureus (MRSA), gastroentritis due to unclean water, and cholera, pertussis, among others." ;
    skos:prefLabel "Bacterial Disease"@en .

:BlizzardStorm a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "A low-pressure system in winter months with significant accumulations of snow, freezing rain, sleet, or ice. A blizzard is a severe snowstorm with winds exceeding 35 mph (56 km/h) for three or more hours, producing reduced visibility (less than 0.25 miles (400 m))." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Blizzard storm: A low-pressure system in winter months with significant accumulations of snow, freezing rain, sleet, or ice. A blizzard is a severe snowstorm with winds exceeding 35 mph (56 km/h) for three or more hours, producing reduced visibility (less than 0.25 miles (400 m))." ;
    skos:prefLabel "Blizzard Storm"@en .

:ChemicalSpill a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Accident release occurring during the production, transportation, or handling of hazardous chemical substances." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Chemical spill: Accident release occurring during the production, transportation, or handling of hazardous chemical substances." ;
    skos:prefLabel "Chemical Spill"@en .

:CoastalFlood a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Flood ;
    skos:definition "Higher-than-normal water levels along the coast caused by tidal changes or thunderstorms that result in flooding, which can last from days to weeks. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Coastal flood: Flood along the coast caused by tidal changes or storms. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas." ;
    skos:prefLabel "Coastal Flood"@en .

:ColdWave a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :ExtremeTemperature ;
    skos:definition "A period of abnormally cold weather. Typically a cold wave lasts two or more days and may be aggravated by high winds. The exact temperature criteria for what constitutes a cold wave vary by location. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Cold wave: A period of abnormally cold weather. Typically, a cold wave lasts for two or more days and may be aggravated by high winds. The exact temperature criteria for what constitutes a cold wave may vary by location." ;
    skos:prefLabel "Cold Wave"@en .

:CollapseIndustrial a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Accident involving the collapse of a building or structure. Can either involve industrial structures or domestic/non-industrial structures." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Collapse (industrial): Accident involving the fall or collapse of a building or structure. Can involve fallen industrial or commercial structures like billboards, towers, stores. Can be due to typhoons, ropical storms, tropical cyclones, tropical depressions." ;
    skos:prefLabel "Collapse (Industrial)"@en .

:CollapseMiscellaneous a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MiscellaneousAccident ;
    skos:definition "Accident involving the collapse of a building or structure. Can either involve industrial structures or domestic/non-industrial structures." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Collapse of a building or structure. Can involve fallen debris, fallen tree/s, uprooted trees, toppled posts, and soil collapse. Can be due to typhoons, strong winds, tropical storms, tropical cyclones, tropical depressions." ;
    skos:prefLabel "Collapse (Misc)"@en .

:Derecho a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "Widespread and usually fast-moving windstorms associated with convection/convective storm. Derechos include downburst and straight-line winds. The damage from derechos is often confused with the damage from tornadoes. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Derecho: Windstorms associated with a convection. Derechos include downburst and straight-line winds." ;
    skos:prefLabel "Derecho"@en .

:Drought a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Climatological ;
    skos:definition "An extended period of unusually low precipitation that produces a shortage of water for people, animals, and plants. Drought is different from most other hazards in that it develops slowly, sometimes even over the years, and its onset is generally difficult to detect. Drought is not solely a physical phenomenon because its impacts can be exacerbated by human activities and water supply demands. Drought is therefore often defined both conceptually and operationally. Operational definitions of drought, i.e., the degree of precipitation reduction that constitutes a drought, vary by locality, climate, and environmental sector. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Drought: An extended period of unusually low precipitation that produces a shortage of water for people, animals, and plants. Drought is different from most other hazards in that it develops slowly, sometimes even over the years, and its onset is generally difficult to detect. Drought is not solely a physical phenomenon because its impacts can be exacerbated by human activities and water supply demands. Drought is therefore often defined both conceptually and operationally. Operational definitions of drought, i.e., the degree of precipitation reduction that constitutes a drought, vary by locality, climate, and environmental sector. Can be considered dry spell. Can be due to El Nino" ;
    skos:prefLabel "Drought"@en .

:ExplosionIndustrial a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Explosions involving buildings or structures. Can involve industrial structures" ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Explosion (industrial): Explosions involving buildings or structures. Can involve industrial structures like factories." ;
    skos:prefLabel "Explosion (Industrial)"@en .

:ExplosionMiscellaneous a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MiscellaneousAccident ;
    skos:definition "Explosions involving buildings or structures. Can involve industrial structures." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Explosion (miscellaneous): Non-industrial explosions involving buildings or structures. Grenade/bomb explosions. Can be due to elections and holidays." ;
    skos:prefLabel "Explosion (Misc)"@en .

:ExtratropicalStorm a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "A type of low-pressure cyclonic system in the middle and high latitudes (also called mid-latitude cyclone) that primarily gets its energy from the horizontal temperature contrasts (fronts) in the atmosphere. When associated with cold fronts, extratropical cyclones may be particularly damaging (e.g., European winter/windstorm, Nor’easter). " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Extratropical storm: A type of cyclonic system in the middle and high latitudes (also called a mid-latitude cyclone) that primarily gets its energy from the horizontal temperature contrasts (fronts) in the atmosphere. When associated with cold fronts, extra-tropical cyclones may be particularly damaging (e.g., European winter/windstorm, or Nor'easter)." ;
    skos:prefLabel "Extratropical Storm"@en .

:FireIndustrial a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Urban fire involving buildings or structures. Can involve industrial structures." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Fire (industrial): Fire incidents involving industrial buildings or structures. Can involve industrial structures like factories." ;
    skos:prefLabel "Fire (Industrial)"@en .

:FireMiscellaneous a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MiscellaneousAccident ;
    skos:definition "Urban fire involving buildings or structures. Can involve industrial structures." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Fire (miscellaneous): Non-industrial fire incidents. Can involve residential structures." ;
    skos:prefLabel "Fire (Misc)"@en .

:FlashFlood a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Flood ;
    skos:definition "Heavy or excessive rainfall in a short period of time that produce immediate runoff, creating flooding conditions within minutes or a few hours during or after the rainfall. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Flash flood: Heavy or excessive rainfall in a short period of time that produces immediate runoff, creating flooding conditions within minutes or a few hours during or after the rainfall. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas." ;
    skos:prefLabel "Flash Flood"@en .

:FloodGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Flood ;
    skos:definition "A general term for the overflow of water from a stream channel onto normally dry land in the floodplain (riverine flooding), higher-than-normal levels along the coast (coastal flooding) and in lakes or reservoirs as well as ponding of water at or near the point where the rain fell (flash floods)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Flood (General): A general term for flooded areas (subsided, receding, or still flooded) or floodwaters and the overflow of water levels. Barangays and sitios affected, damaged and normally flooded in ft. Involves flooding in roads, zones, and areas in the country, affecting families and households. Can involve overflow or box of culverts, knee, waist, and gutter-deep levels of water. Sheet flooding. Can be due to heavy rains, monsoons, tropical storms, tropical cyclones, tropical depressions, and low pressure areas." ;
    skos:prefLabel "Flood (General)"@en .

:Fog a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Meteorological ;
    skos:definition "Water droplets that are suspended in the air near the Earth’s surface. Fog is simply a cloud that is in contact with the ground. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Fog: Water droplets that are suspended in the air near the Earth's surface. Fog is, in fact, simply a cloud that is in contact with the ground." ;
    skos:prefLabel "Fog"@en .

:ForestFire a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Wildfire ;
    skos:definition "A type of wildfire in a wooded area. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Forest Fire: A type of wildfire in a wooded area or forest. Can be due to El Nino." ;
    skos:prefLabel "Forest Fire"@en .

:FungalDisase a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Epidemic ;
    skos:definition "An unusual increase in the number of cases caused by exposure to fungi either through skin contact, ingestion, or inhalation of spores. Examples are fungal pneumonia, fungal meningitis, etc." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Fungal Disease: An unusual increase in the number of cases caused by exposure to fungi either through skin contact, ingestion, or inhalation of spores. Examples are fungal pneumonia, fungal meningitis, etc." ;
    skos:prefLabel "Fungal Disease" .

:GasLeak a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Gas leak incidents." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Gas leak incidents." ;
    skos:prefLabel "Gas Leak"@en .

:Glacial a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:altLabel "Glacial Lake Outburst" ;
    skos:broader :Climatological ;
    skos:definition "A flood that occurs when water dammed by a glacier or moraine is suddenly released. Glacial lakes can be at the front of the glacier (marginal lake) or below the ice sheet (sub-glacial lake).  " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Glacial: Occurs when water held back by a glacier or moraine is suddenly released. Glacial lakes can be at the front of the glacier (marginal lake) or below the ice sheet (sub-glacial lake)." ;
    skos:prefLabel "Glacial"@en .

:GrasshopperInfestation a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Infestation ;
    skos:definition "Infestation of grasshoppers (insects)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Infestation of grasshoppers (insects)." ;
    skos:prefLabel "Grasshopper Infestation"@en .

:GroundMovement a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Earthquake ;
    skos:definition "Surface displacement of earthen materials due to ground shaking triggered by earthquakes or volcanic eruptions. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Ground movement: Surface displacement of earthen materials due to ground shaking triggered by earthquakes or volcanic eruptions. Often described with magnitudes, intensities, and epicenters." ;
    skos:prefLabel "Ground Movement"@en .

:Hail a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "Solid precipitation in the form of irregular pellets or balls of ice more than 5 mm in diameter. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Hail: Solid precipitation in the form of irregular pellets or balls of ice more than 5 mm in diameter." ;
    skos:prefLabel "Hail"@en .

:HeatWave a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :ExtremeTemperature ;
    skos:definition "A period of abnormally hot and/or unusually humid weather. Typically a heat wave lasts two or more days. The exact temperature criteria for what constitutes a heat wave vary by location.  " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Heat wave: A period of abnormally hot and/or unusually humid weather. Typically, a heat wave lasts for two or more days. The exact temperature criteria for what constitutes a heat wave may vary by location." ;
    skos:prefLabel "Heat Wave"@en .

:IceJamFlood a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Flood ;
    skos:definition "The accumulation of floating ice restricting or blocking a river’s flow and drainage. Ice jams tend to develop near river bends and obstructions (e.g., bridges).  " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Ice Jam: The accumulation of floating ice restricting or blocking a river's flow and drainage. Ice jams tend to develop near river bends and obstructions (e.g., bridges)." ;
    skos:prefLabel "Ice Jam Flood"@en .

:IndustrialAccidentGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Disaster type term used in EM-DAT to describe technological accidents of an industrial nature/involving industrial buildings (e.g. factories)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Industrial accident (general): Any form of general industrial accidents." ;
    skos:prefLabel "Industrial Accident (General)"@en .

:InfectiousDiseaseGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Epidemic ;
    skos:definition "Either an unusual, often sudden, increase in the number of cases of an infectious disease that already existed in the region (e.g., flu, or E. coli) or the appearance of an infectious disease previously absent from the region (e.g., plague, or polio)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Infectious disease (general): Either an unusual, often sudden, increase in the number of cases or outbreak of an infectious disease that already existed in the region (e.g., flu, or E. coli, gastroentritis or the appearance of an infectious disease previously absent from the region (e.g., plague, or polio)." ;
    skos:prefLabel "Infectious Disease (General)"@en .

:InfestationGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Infestation ;
    skos:definition "The pervasive influx, swarming and/or hatching of insects, worms, or other animals affecting humans, animals, crops, and perishable goods." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Infestation (general): The pervasive influx, swarming and/or hatching of insects, worms, or other animals affecting humans, animals, crops, and perishable goods." ;
    skos:prefLabel "Infestation (General)"@en .

:Lahar a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :VolcanicActivity ;
    skos:definition "Hot or cold mixture of earthen material flowing on the slope of a volcano either during or between volcanic eruptions. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Lahar: Hot or cold mixture of earthen material flowing down the slope of a volcano either during or between volcanic eruptions." ;
    skos:prefLabel "Lahar"@en .

:LandFire a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Wildfire ;
    skos:definition "A type of wildfire in a brush, bush, pasture, grassland, or other treeless natural environment." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Land Fire: A type of wildfire in a brush, bush, pasture, grassland, or other treeless natural environment. Can be due to El Nino." ;
    skos:prefLabel "Land Fire"@en .

:LandslideDry a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementDry ;
    skos:definition "Any kind of moderate to rapid soil movement incl. lahars, mudslides, and debris flows (under dry conditions). A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Landslide (dry): Any kind of moderate to rapid soil movement, can be and often induced by an earthquake (under dry conditions) bringing damage. A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face. Often due to earthquakes and affecting houses." ;
    skos:prefLabel "Landslide (Dry)"@en .

:LandslideWet a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementWet ;
    skos:definition "Any kind of moderate to rapid soil movement incl. lahars, mudslides, and debris flows (under wet conditions). A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Landslide (wet): Any kind of moderate to rapid soil movement, can be induced by rain (under wet conditions) bringing damage. Can be due to tropical cyclones, stroms, depressions. A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face.  Often due to rain and affecting houses." ;
    skos:prefLabel "Landslide (Wet)"@en .

:LavaFlow a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :VolcanicActivity ;
    skos:definition "The ejected magma that moves as a liquid mass downslope from a volcano during an eruption. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Lava Flow: The ejected magma that moves as a liquid mass downslope from a volcano during an eruption." ;
    skos:prefLabel "Lava Flow"@en .

:LocustInfestation a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Infestation ;
    skos:definition "Infestation of locusts (insects)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Infestation of locusts (insects)." ;
    skos:prefLabel "Locust Infestation"@en .

:MiscellaneousAccidentGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MiscellaneousAccident ;
    skos:definition "Disaster type term used in EM-DAT to describe technological accidents of a non-industrial or transport nature (e.g., involving houses)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Miscellaneous accident (general): Can involve fireworks or firework-related incidents (injuries) or events about elections, celebrations (year-end, christmas), observance of holidays (such as the Lenten season, Undas, All Saints' Day and All Soul's Day). Can involve drowning incidents and food poisoning. Does not include transport or vehicular accidents." ;
    skos:prefLabel "Miscellaneous Accident (General)"@en .

:Mudslide a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementWet ;
    skos:definition "A form of mass wasting involving fast-moving flow of debris and dirt that has become liquified by the addition of water." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Mudslide: A form of mass wasting involving fast-moving flow of debris and dirt that has become liquified by the addition of water. Also called a mudflow. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas." ;
    skos:prefLabel "Mudslide"@en .

:OilSpill a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Accident release occurring during the production, transportation, or handling of oil." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Oil spill: Accident release occurring during the production, transportation, or handling of oil." ;
    skos:prefLabel "Oil Spill"@en .

:ParasiticDisease a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Epidemic ;
    skos:definition "An unusual increase in the number of cases caused by exposure to a parasite, i.e., an organism living on or in a host. Exposure to parasites occurs mostly through contaminated water, food, or contact with insects, animals, etc. Examples are malaria, Chagas disease, giardiasis, and Trichinellosis." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Parasitic disease: An unusual increase in the number of cases caused by exposure to a parasite, i.e., an organism living on or in a host. Exposure to parasites occurs mostly through contaminated water, food, or contact with insects, animals, etc. Examples are malaria, Chagas disease, giardiasis, and Trichinellosis." ;
    skos:prefLabel "Parasitic Disease"@en .

:Poisoning a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Poisoning of atmosphere or water courses due to industrial sources of contamination." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Poisoning of atmosphere or water courses due to industrial sources of contamination." ;
    skos:prefLabel "Poisoning"@en .

:PrionDisease a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Epidemic ;
    skos:definition "A type of biological hazard caused by prion proteins. Prion diseases or transmissible spongiform encephalopathies (TSEs) are a family of rare progressive neurodegenerative disorders that affect both humans and animals. They are characterized by long incubation periods and neural loss. Examples are Bovine Spongiform Encephalopathy (BSE), Creutzfeldt-Jakob Disease (CJD), Kuru, etc." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Prion disease: A type of biological hazard caused by prion proteins. Prion diseases or transmissible spongiform encephalopathies (TSEs) are a family of rare progressive neurodegenerative disorders that affect both humans and animals. They are characterized by long incubation periods and neural loss. Examples are Bovine Spongiform Encephalopathy (BSE), Creutzfeldt-Jakob Disease (CJD), Kuru, etc." ;
    skos:prefLabel "Prion Disease"@en .

:PyroclasticFlow a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :VolcanicActivity ;
    skos:definition "Extremely hot gases, ash, and other materials of more than 1,000 degrees Celsius that rapidly flow down the flank of a volcano (more than 700 km/h) during an eruption.  " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Pyroclastic Flow: Extremely hot gases, ash, and other materials with a temperature of more than 1,000 degrees Celsius that rapidly flow down the flank of a volcano (at more than 700 km/h) during an eruption." ;
    skos:prefLabel "Pyroclastic Flow"@en .

:Radiation a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :IndustrialAccident ;
    skos:definition "Exposure to harmful radiation or reactive substances." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Radiation: Exposure to harmful radiation or reactive substances." ;
    skos:prefLabel "Radiation"@en .

:Rail a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Transport ;
    skos:definition "Transport accidents involving trains." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Rail: Transport accidents involving trains." ;
    skos:prefLabel "Rail"@en .

:RiverineFlood a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Flood ;
    skos:definition "A type of flooding resulting from the overflow of water from a stream or river channel onto normally dry land in the floodplain adjacent to the channel." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Riverine flood: A type of flooding resulting due to the river (swollen river) or overflowing of a stream, creek, or  channel onto normally dry land in the floodplain adjacent to the channel." ;
    skos:prefLabel "Riverine Flood"@en .

:Road a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Transport ;
    skos:definition "Transport accidents involving motor vehicles on roads and tracks." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Road: Transport or vehicular accidents involving motor vehicles on roads and tracks. Can be due to heavy rainfall, earthquakes, or certain special events like holidays. Can involve road cuts and collisions." ;
    skos:prefLabel "Road"@en .

:RockfallDry a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementDry ;
    skos:definition "A quantity of rock that has fallen from a cliff face or from the roof or walls of mine or quarry workings under dry conditions." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Rockfall (dry): A quantity of rock that has fallen from a cliff face or from the roof or walls of mine or quarry workings under dry conditions. Also called rock slide under dry conditions. Can be due to earthquakes. Can occur near roads." ;
    skos:prefLabel "Rockfall (Dry)"@en .

:RockfallWet a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementWet ;
    skos:definition "A quantity of rock or boulders that has fallen from a cliff face, mountain or from the roof or walls of mine or quarry workings under wet conditions or rain." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Rockfall (wet): A quantity of rock or boulders that has fallen from a cliff face, mountain or from the roof or walls of mine or quarry workings under wet conditions or rain. Also called rock slide under wet conditions. Can be due to tropical cyclones, tropical storms, tropical depressions, shear line, monsoons. Sometimes reported to hit structures." ;
    skos:prefLabel "Rockfall (Wet)"@en .

:RogueWave a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :WaveAction ;
    skos:definition "An unusual single crest of an ocean wave far out at sea that is much higher and/or steeper than other waves in the prevailing swell system. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Rouge wave: An unusual single crest of an ocean wave far out at sea that is much higher and/or steeper than other waves in the prevailing swell system." ;
    skos:prefLabel "Rogue Wave"@en .

:SandStorm a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "Strong winds carry particles of sand aloft, but generally confined to less than 50 feet (15 m), especially common in arid and semi-arid environments. A dust storm is also characterised by strong winds but carries smaller particles of dust rather than sand over an extensive area. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Sand storm: Strong winds carrying particles of sand aloft, but generally confined to less than 50 feet (15 m), especially common in arid and semi-arid environments. A dust storm is also characterized by strong winds but carries smaller particles of dust rather than sand over an extensive area." ;
    skos:prefLabel "Sand Storm"@en .

:Seiche a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :WaveAction ;
    skos:definition "A standing wave of water in a large semi- or fully-enclosed body of water (lakes or bays) created by strong winds and/or a large barometric pressure gradient. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Seiche: A standing wave of water in a large semi- or fully-enclosed body of water (lakes or bays) created by strong winds and/or a large barometric pressure gradient." ;
    skos:prefLabel "Seiche"@en .

:SevereWeather a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "Severe weather, heavy rains and strong winds bringing damage." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Severe weather, heavy rains and strong winds bringing damage." ;
    skos:prefLabel "Severe Weather"@en .

:SevereWinterConditions a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :ExtremeTemperature ;
    skos:definition "Damage caused by snow and ice. Winter damage refers to damage to buildings, infrastructure, traffic (esp. navigation) inflicted by snow and ice in the form of snow pressure, freezing rain, frozen waterways etc." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Severe winter conditions: Damage caused by snow and ice. Winter damage refers to damage to buildings, infrastructure, traffic (esp. navigation) inflicted by snow and ice in the form of snow pressure, freezing rain, frozen waterways etc." ;
    skos:prefLabel "Severe Winter Conditions"@en .

:SpaceImpact a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Extraterrestrial ;
    skos:definition "A type of extra-terrestrial hazard caused by the collision a meteoroid, asteroid, or comet with the Earth." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Space impact: A type of extra-terrestrial hazard caused by the collision a meteoroid, asteroid, or comet with the Earth." ;
    skos:prefLabel "Space Impact"@en .

:SpaceWeather a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Extraterrestrial ;
    skos:definition "A general term for extraterrestrial weather conditions driven by solar eruptions such as geomagnetic storms, radio disturbances, and solar energetic particles. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Space weather: A general term for extra-terrestrial weather conditions driven by solar eruptions such as geomagnetic storms, radio disturbances, and solar energetic particles." ;
    skos:prefLabel "Space Weather"@en .

:StormGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "Can be weather disturbances brought by monsoons (southwest or northeast monsoons), low pressure areas and shear lines that can bring effects like flooding, flashfloods, thunderstorms, and heavy rains." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Storm general: Can be storms brought by monsoons (southwest or northeast monsoons), low pressure areas and shear lines that can bring effects like flooding, flashfloods, thunderstorms, and heavy rains." ;
    skos:prefLabel "Storm (General)"@en .

:StormSurge a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "An abnormal rise in sea level generated by a tropical cyclone or other intense storms. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Storm Surge: An abnormal surge or rise in sea level. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas." ;
    skos:prefLabel "Storm Surge"@en .

:SuddenSubsidenceDry a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementDry ;
    skos:definition "Sinking of the ground due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under dry conditions as a result of a geophysical trigger. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Sudden subsidence (dry): Sinking of the ground due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under dry conditions as a result of a geophysical trigger. Can involve liquefaction and can be due to earthquakes." ;
    skos:prefLabel "Sudden Subsidence (Dry)"@en .

:SuddenSubsidenceWet a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :MassMovementWet ;
    skos:definition "Sinking of the ground due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under wet conditions as a result of a hydrological trigger (e.g., rain). " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Sudden subsidence (wet): Sinking of the ground like liquefaction near rivers or seas due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under wet conditions as a result of a hydrological trigger (e.g., rain). Can be due to tropical cyclones, stroms, depressions as well." ;
    skos:prefLabel "Sudden Subsidence (Wet)"@en .

:Thunderstorms a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "A high-voltage, visible electrical discharge produced by a thunderstorm and followed by the sound of thunder." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Thunderstorms: Lightnings produced by a thunderstorm and followed by the sound of thunder." ;
    skos:prefLabel "Thunderstorms"@en .

:Tornado a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "A violently rotating column of air that reaches the ground or open water (waterspout). " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Tornado: Tornadoes and whirlwinds. A violently rotating column of air that reaches the ground or open water (waterspout). Can be associated with heavy rains and bring damage." ;
    skos:prefLabel "Tornado"@en .

:TropicalCyclone a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Storm ;
    skos:definition "A tropical cyclone originates over tropical or subtropical waters. It is characterised by a warm-core, non-frontal synoptic-scale cyclone with a low pressure centre, spiral rain bands and strong winds. Depending on their location, tropical cyclones are referred to as hurricanes (Atlantic, Northeast Pacific), typhoons (Northwest Pacific), or cyclones (South Pacific and Indian Ocean). " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Tropical Cyclone: Can be called typhoons, super typhoons, tropical storms, tropical depressions, and low pressure areas. Sometimes called TS, TC, TD, LPA plus the name. It is characterized by a warm-core, non-frontal synoptic-scale cyclone with a low-pressure center, spiral rain bands and strong winds. Depending on their location, tropical cyclones are referred to as hurricanes (Atlantic, Northeast Pacific), typhoons (Northwest Pacific), or cyclones (South Pacific and Indian Ocean). A tropical cyclone originates over tropical or subtropical waters." ;
    skos:prefLabel "Tropical Cyclone"@en .

:Tsunami a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Earthquake ;
    skos:definition "A series of waves (with long wavelengths when traveling across the deep ocean) that are generated by a displacement of massive amounts of water through underwater earthquakes, volcanic eruptions or landslides. Tsunami waves travel at very high speed across the ocean but as they begin to reach shallow water they slow down and the wave grows steeper. " ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Tsunami: A series of waves (with long wavelengths when traveling across the deep ocean) that are generated by a displacement of massive amounts of water through underwater earthquakes, volcanic eruptions, or landslides. Tsunami waves travel at very high speed across the ocean, but as they begin to reach shallow water they slow down, and the wave grows steeper." ;
    skos:prefLabel "Tsunami"@en .

:ViralDisease a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Epidemic ;
    skos:definition "An unusual increase in the number of cases caused by exposure to virus either through skin contact, ingestion, or inhalation." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Viral disease: An unusual increase in the number of cases caused by exposure to virus either through skin contact, ingestion, or inhalation. Common viral illnesses include colds, the flu, COVID-19, norovirus (\"stomach flu\"), HPV (warts) and herpes simplex virus (cold sores)" ;
    skos:prefLabel "Viral Disease"@en .

:VolcanicActivityGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :VolcanicActivity ;
    skos:definition "A type of volcanic event near an opening/vent in the Earth’s surface including volcanic eruptions of lava, ash, hot vapor, gas, and pyroclastic material." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Volcanic activity (general): A type of volcanic event near an opening/vent in the Earth's surface including volcanic eruptions of lava, ash, hot vapor, gas, and pyroclastic material. Explosive eruptions in volcanoes." ;
    skos:prefLabel "Volcanic Activity (General)"@en .

:Water a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Transport ;
    skos:definition "Transport accidents involving sailing boats, ferries, cruise ships, and other vessels." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Water: Transport or maritime accidents or incidents involving sailing boats (motorbancas), ferries, cruise ships, and other vessels. Can be due to weather conditions, strong winds, typhoons, tropical storms, cyclones, and depressions." ;
    skos:prefLabel "Water" .

:WaveActionGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :WaveAction ;
    skos:definition "Wind-generated surface waves that can occur on the surface of any open body of water such as oceans, rivers and lakes, etc. The size of the wave depends on the strength of the wind and the traveled distance (fetch)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Wave action (general): Wind-generated surface big waves that can occur near coastal areas or on the surface of any open body of water such as oceans, rivers, or lakes. The size of the wave depends on the strength of the wind and the distance traveled (fetch)." ;
    skos:prefLabel "Wave Action (General)" .

:WildfireGeneral a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Wildfire ;
    skos:definition "Any uncontrolled and non-prescribed combustion or burning of plants in a natural setting such as a forest, grassland, brush land or tundra, which consumes natural fuels and spreads based on environmental conditions (e.g., wind, or topography). Wildfires can be triggered by lightning or human actions." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Wildfire (general): Any type of fire  in a natural setting such as a grassland, mountain, brush land or tundra, which consumes natural fuels such as tress and spreads based on environmental conditions (e.g., wind, or topography). Wildfires can be triggered by lightning or human actions. Can affect animals, trees, and properties. Can be due to El Nino." ;
    skos:prefLabel "Wildfire (General)"@en .

:WormsInfestation a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Infestation ;
    skos:definition "Infestation of worms." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:note "Infestation of worms." ;
    skos:prefLabel "Worms Infestation"@en .

:Earthquake a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Geophysical ;
    skos:definition "Sudden movement of a block of the Earth's crust along a geological fault and associated ground shaking." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :GroundMovement,
        :Tsunami ;
    skos:prefLabel "Earthquake"@en .

:Extraterrestrial a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Natural ;
    skos:definition "A hazard caused by asteroids, meteoroids, and comets as they pass near to the Earth, enter the Earth's atmosphere, and/or strike the Earth, and by changes in interplanetary conditions that effect the Earth's magnetosphere, ionosphere, and thermosphere." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :SpaceImpact,
        :SpaceWeather ;
    skos:prefLabel "Extraterrestrial"@en .

:Biological a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Natural ;
    skos:definition "A hazard caused by exposure to living organisms and/or their toxic substances (e.g., venom, or mold) or vector-borne diseases that they may carry. Examples are venomous wildlife and insects, poisonous plants, algae blooms, and mosquitoes carrying agents that causes disease such as parasites, bacteria, or viruses (e.g., malaria)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :AnimalAccident,
        :Epidemic,
        :Infestation ;
    skos:prefLabel "Biological"@en .

:Climatological a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Natural ;
    skos:definition "A hazard caused by long-lived, meso- to macro-scale atmospheric processes ranging from intra-seasonal to multi-decadal climate variability." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :Drought,
        :Glacial,
        :Wildfire ;
    skos:prefLabel "Climatological"@en .

:ExtremeTemperature a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Meteorological ;
    skos:definition "A general term for temperature variations above (extreme heat) or below (extreme cold) normal conditions." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :ColdWave,
        :HeatWave,
        :SevereWinterConditions ;
    skos:prefLabel "Extreme Temperature"@en .

:Geophysical a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Natural ;
    skos:definition "A hazard originating from solid earth. This term is used interchangeably with the term geological hazard." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :Earthquake,
        :MassMovementDry,
        :VolcanicActivity ;
    skos:prefLabel "Geophysical"@en .

:Hydrological a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Natural ;
    skos:definition "A hazard caused by the occurrence, movement, and distribution of surface and subsurface freshwater and saltwater." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :Flood,
        :MassMovementWet,
        :WaveAction ;
    skos:prefLabel "Hydrological"@en .

:Meteorological a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Natural ;
    skos:definition "A hazard caused by short-lived, micro- to meso-scale extreme weather and atmospheric conditions that last from minutes to days." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :ExtremeTemperature,
        :Fog,
        :Storm ;
    skos:prefLabel "Meteorological"@en .

:WaveAction a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Hydrological ;
    skos:definition "Wind-generated surface waves that can occur on the surface of any open body of water such as oceans, rivers and lakes, etc. The size of the wave depends on the strength of the wind and the traveled distance (fetch)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :RogueWave,
        :Seiche,
        :WaveActionGeneral ;
    skos:prefLabel "Wave Action"@en .

:Wildfire a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Climatological ;
    skos:definition "Any uncontrolled and non-prescribed combustion or burning of plants in a natural setting such as a forest, grassland, brush land or tundra, which consumes natural fuels and spreads based on environmental conditions (e.g., wind, or topography). Wildfires can be triggered by lightning or human actions." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :ForestFire,
        :LandFire,
        :WildfireGeneral ;
    skos:prefLabel "Wildfire"@en .

:Infestation a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Biological ;
    skos:definition "The pervasive influx, swarming and/or hatching of insects, worms, or other animals affecting humans, animals, crops, and perishable goods." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :GrasshopperInfestation,
        :InfestationGeneral,
        :LocustInfestation,
        :WormsInfestation ;
    skos:prefLabel "Infestation"@en .

:MassMovementDry a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Geophysical ;
    skos:definition "Any type of downslope movement of earth materials under hydrological dry conditions." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :AvalancheDry,
        :LandslideDry,
        :RockfallDry,
        :SuddenSubsidenceDry ;
    skos:prefLabel "Mass Movement (Dry)"@en .

:MiscellaneousAccident a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Technological ;
    skos:definition "Disaster type term used in EM-DAT to describe technological accidents of a non-industrial or transport nature (e.g., involving houses)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :CollapseMiscellaneous,
        :ExplosionMiscellaneous,
        :FireMiscellaneous,
        :MiscellaneousAccidentGeneral ;
    skos:prefLabel "Miscellaneous Accident"@en .

:Technological a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:definition "Man-made events causing impact and technological incidents." ;
    skos:example "Armed conflict, chemical spill, or industrial fires." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :ArmedConflict,
        :IndustrialAccident,
        :MiscellaneousAccident,
        :Transport ;
    skos:prefLabel "Technological"@en ;
    skos:topConceptOf :DisasterTypeScheme .

:Transport a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Technological ;
    skos:definition "Disaster type term used to describe technological transport accidents involving mechanized modes of transport. It comprises four disaster subtypes (i.e., Air, Water, Rail, and Road)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :Air,
        :Rail,
        :Road,
        :Water ;
    skos:prefLabel "Transport"@en .

:Flood a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Hydrological ;
    skos:definition "A general term for the overflow of water from a stream channel onto normally dry land in the floodplain (riverine flooding), higher-than-normal levels along the coast (coastal flooding) and in lakes or reservoirs as well as ponding of water at or near the point where the rain fell (flash floods)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :CoastalFlood,
        :FlashFlood,
        :FloodGeneral,
        :IceJamFlood,
        :RiverineFlood ;
    skos:prefLabel "Flood"@en .

:MassMovementWet a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Hydrological ;
    skos:definition "Types of mass movement that occur when heavy rain or rapid snow/ice melt send large amounts of vegetation, mud, or rock down a slope driven by gravitational forces." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :AvalancheWet,
        :LandslideWet,
        :Mudslide,
        :RockfallWet,
        :SuddenSubsidenceWet ;
    skos:prefLabel "Mass Movement (Wet)"@en .

:VolcanicActivity a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Geophysical ;
    skos:definition "A type of volcanic event near an opening/vent in the Earth's surface including volcanic eruptions of lava, ash, hot vapor, gas, and pyroclastic material." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :Ashfall,
        :Lahar,
        :LavaFlow,
        :PyroclasticFlow,
        :VolcanicActivityGeneral ;
    skos:prefLabel "Volcanic Activity"@en .

:Epidemic a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Biological ;
    skos:definition "Either an unusual, often sudden, increase in the number of cases of an infectious disease that already existed in the region (e.g., flu, or E. coli) or the appearance of an infectious disease previously absent from the region (e.g., plague, or polio)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :BacterialDisease,
        :FungalDisase,
        :InfectiousDiseaseGeneral,
        :ParasiticDisease,
        :PrionDisease,
        :ViralDisease ;
    skos:prefLabel "Epidemic"@en .

:Natural a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:closeMatch baw:NaturalDisasterType ;
    skos:definition "Naturally occurring disastrous events" ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :Biological,
        :Climatological,
        :Extraterrestrial,
        :Geophysical,
        :Hydrological,
        :Meteorological ;
    skos:prefLabel "Natural"@en ;
    skos:topConceptOf :DisasterTypeScheme .

:IndustrialAccident a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Technological ;
    skos:definition "Disaster type term used in EM-DAT to describe technological accidents of an industrial nature/involving industrial buildings (e.g. factories)." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :ChemicalSpill,
        :CollapseIndustrial,
        :ExplosionIndustrial,
        :FireIndustrial,
        :GasLeak,
        :IndustrialAccidentGeneral,
        :OilSpill,
        :Poisoning,
        :Radiation ;
    skos:prefLabel "Industrial Accident"@en .

:Storm a owl:NamedIndividual,
        skos:Concept,
        :DisasterType ;
    skos:broader :Meteorological ;
    skos:definition "Can be weather disturbances brought by monsoons (southwest or northeast monsoons), low pressure areas and shear lines that can bring effects like flooding, flashfloods, thunderstorms, and heavy rains." ;
    skos:inScheme :DisasterTypeScheme ;
    skos:narrower :BlizzardStorm,
        :Derecho,
        :ExtratropicalStorm,
        :Hail,
        :SandStorm,
        :SevereWeather,
        :StormGeneral,
        :StormSurge,
        :Thunderstorms,
        :Tornado,
        :TropicalCyclone ;
    skos:prefLabel "Storm"@en .

:DisasterTypeScheme a owl:NamedIndividual,
        skos:Concept,
        skos:ConceptScheme,
        :DisasterTypeScheme ;
    rdfs:label "Disaster Type Scheme" ;
    skos:definition "Disaster type based on the Emergency Events Database (EM-DAT) classification of disasters." ;
    skos:hasTopConcept :Natural,
        :Technological ;
    skos:prefLabel "SakunaGraPH Disaster Type Classification Scheme"@en .

