    <!-- https://sakuna.ph/Source -->

    <owl:Class rdf:about="https://sakuna.ph/Source">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
