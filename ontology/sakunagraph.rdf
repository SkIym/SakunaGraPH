                <owl:someValuesFrom rdf:resource="https://sakuna.ph/Region"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Province</rdfs:label>
        <skos:definition>Administrative Level 2</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Recovery -->

    <owl:Class rdf:about="https://sakuna.ph/Recovery">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Response"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/policyChanges"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/postStructureCost"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/postTraining"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/srrDone"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Recovery</rdfs:label>
        <skos:definition>Represents civic repercussions and changes made to recover after the disaster event.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Region -->

    <owl:Class rdf:about="https://sakuna.ph/Region">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/isPartOf"/>
                <owl:someValuesFrom rdf:resource="https://sakuna.ph/IslandGroup"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Region</rdfs:label>
        <skos:definition>Administrative Level 1</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Relief -->

    <owl:Class rdf:about="https://sakuna.ph/Relief"/>
    


    <!-- https://sakuna.ph/Rescue -->

    <owl:Class rdf:about="https://sakuna.ph/Rescue">
