    <!-- https://sakuna.ph/hasLocation -->

    <owl:ObjectProperty rdf:about="https://sakuna.ph/hasLocation">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/DisasterEvent"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Impact"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Preparedness"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Response"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://sakuna.ph/Location"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://sakuna.ph/hasImpact"/>
            <rdf:Description rdf:about="https://sakuna.ph/hasLocation"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://sakuna.ph/hasPreparedness"/>
            <rdf:Description rdf:about="https://sakuna.ph/hasLocation"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://sakuna.ph/hasRelatedIncident"/>
            <rdf:Description rdf:about="https://sakuna.ph/hasLocation"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://sakuna.ph/hasResponse"/>
            <rdf:Description rdf:about="https://sakuna.ph/hasLocation"/>
        </owl:propertyChainAxiom>
        <rdfs:label xml:lang="en">has location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://sakuna.ph/hasMunicipality -->

    <owl:ObjectProperty rdf:about="https://sakuna.ph/hasMunicipality">
        <rdfs:subPropertyOf rdf:resource="https://sakuna.ph/hasLocation"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/DisasterEvent"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Impact"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Preparedness"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Response"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://sakuna.ph/Municipality"/>
        <rdfs:comment>Synonymous with City</rdfs:comment>
        <rdfs:label xml:lang="en">has municipality or city</rdfs:label>
    </owl:ObjectProperty>
    


