    <!-- https://sakuna.ph/strandedMotorBancas -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/strandedMotorBancas">
        <rdfs:domain rdf:resource="https://sakuna.ph/StrandedEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">no. of stranded motor bancas</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/strandedPassengers -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/strandedPassengers">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/AirportDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/StrandedEvent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">no. of stranded passengers</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/strandedRollingCargoes -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/strandedRollingCargoes">
        <rdfs:domain rdf:resource="https://sakuna.ph/StrandedEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">no. of stranded rolling cargoes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/strandedVessels -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/strandedVessels">
        <rdfs:domain rdf:resource="https://sakuna.ph/StrandedEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">no of. stranded vessels</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/substation -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/substation">
        <rdfs:domain rdf:resource="https://sakuna.ph/StrandedEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">substation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/suspensionType -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/suspensionType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/ClassSuspension"/>
                    <rdf:Description rdf:about="https://sakuna.ph/WorkSuspension"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">suspension type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/telecompany -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/telecompany">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://sakuna.ph/CommunicationLineDisruption"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">telecompany</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/toClassLevel -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/toClassLevel">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://sakuna.ph/ClassSuspension"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">to class level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/totallyDamagedCropArea -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/totallyDamagedCropArea">
        <rdfs:domain rdf:resource="https://sakuna.ph/AgricultureDamage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>in hectares</rdfs:comment>
        <rdfs:label xml:lang="en">totally damaged crop area</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/totallyDamagedHouses -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/totallyDamagedHouses">
        <rdfs:domain rdf:resource="https://sakuna.ph/HousingDamage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">totally damaged houses</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/totallyDamagedInfrastructure -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/totallyDamagedInfrastructure">
        <rdfs:domain rdf:resource="https://sakuna.ph/AgricultureDamage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:label xml:lang="en">totally damaged infrastructure</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://sakuna.ph/urbanRural -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/urbanRural">
        <rdfs:domain rdf:resource="https://sakuna.ph/Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>urban or rural</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://qudt.org/schema/qudt/CurrencyUnit -->

    <owl:Class rdf:about="http://qudt.org/schema/qudt/CurrencyUnit">
        <rdfs:label xml:lang="en">Currency Unit</rdfs:label>
    </owl:Class>
    


    <!-- http://qudt.org/schema/qudt/QuantityValue -->

    <owl:Class rdf:about="http://qudt.org/schema/qudt/QuantityValue">
        <rdfs:label xml:lang="en">Quantity Value</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:label xml:lang="en">Feature</rdfs:label>
        <skos:definition xml:lang="en">A discrete spatial phenomenon in a universe of discourse.</skos:definition>
    </owl:Class>
    


    <!-- https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Impact -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Impact">
        <owl:equivalentClass rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:label>Impact</rdfs:label>
        <skos:definition>Represents the impact of natural disasters and incidents.</skos:definition>
    </owl:Class>
    


    <!-- https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Incident -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Incident">
        <owl:equivalentClass rdf:resource="https://sakuna.ph/Incident"/>
        <rdfs:label>Incident</rdfs:label>
        <skos:definition>Represents the various incidents taking place during a natural disaster.</skos:definition>
    </owl:Class>
    


    <!-- https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Location -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Location">
        <owl:equivalentClass rdf:resource="https://sakuna.ph/Location"/>
    </owl:Class>
    


    <!-- https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#NaturalDisaster -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#NaturalDisaster">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/DisasterEvent"/>
        <rdfs:label>Natural Disaster</rdfs:label>
        <skos:definition>Represents the actual manifestation of a natural disaster type. An instance of a natural disaster has specific climate conditions with specific values (e.g. temperature = 45) plus some other properties (e.g. start/end time).</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/AffectedPopulation -->

    <owl:Class rdf:about="https://sakuna.ph/AffectedPopulation">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/affectedBarangays"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/affectedFamilies"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/affectedPersons"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/displacedFamilies"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/displacedPersons"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Affected Population</rdfs:label>
        <skos:definition>Represents affected and displaced persons or families.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/AgricultureDamage -->

    <owl:Class rdf:about="https://sakuna.ph/AgricultureDamage">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/agriDamageAmount"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/agriDamageClassification"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/agriDamageQuantity"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/agriDamageType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/agriDamageUnit"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/farmerFisherfolkAffected"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/partiallyDamagedCropArea"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/partiallyDamagedInfrastructure"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/productionLossCost"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/productionLossVolume"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/totallyDamagedCropArea"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/totallyDamagedInfrastructure"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Agriculture Damage</rdfs:label>
        <skos:definition>Represents damage on agriculture, farmers, fisherfolks, and crops.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/AirportDisruption -->

    <owl:Class rdf:about="https://sakuna.ph/AirportDisruption">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/affectedDescription"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/cancellationDateTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/portOrTerminalName"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/portStatus"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/resumptionDateTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/ClassSuspension"/>
                    <rdf:Description rdf:about="https://sakuna.ph/CommunicationLineDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/PowerDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/RoadAndBridgesDamage"/>
                    <rdf:Description rdf:about="https://sakuna.ph/SeaportDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/WaterDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/WorkSuspension"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:disjointWith>
        <rdfs:label>Airport Disruption</rdfs:label>
        <skos:altLabel>Flight Disruption</skos:altLabel>
        <skos:definition>Represents disruptions on airports.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Assistance -->

    <owl:Class rdf:about="https://sakuna.ph/Assistance">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Response"/>
        <rdfs:label xml:lang="en">Assistance</rdfs:label>
        <skos:altLabel>Relief</skos:altLabel>
        <skos:definition>Represents the monetary assistance provided during or after a disaster event.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Barangay -->

    <owl:Class rdf:about="https://sakuna.ph/Barangay">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/isPartOf"/>
                <owl:someValuesFrom rdf:resource="https://sakuna.ph/Municipality"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Barangay</rdfs:label>
        <skos:definition>Administrative Level 4</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Casualties -->

    <owl:Class rdf:about="https://sakuna.ph/Casualties">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/casualtyCause"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/casualtyCount"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/casualtyDataSource"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/casualtyType"/>
                <owl:someValuesFrom rdf:resource="https://sakuna.ph/casualtyDatatype"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Casualties</rdfs:label>
        <skos:definition>Represents the number of deaths, injured, and missing due to a disaster.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/City -->

    <owl:Class rdf:about="https://sakuna.ph/City">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Location"/>
        <rdfs:label>City</rdfs:label>
        <skos:definition>Administrative Level 3</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/ClassSuspension -->

    <owl:Class rdf:about="https://sakuna.ph/ClassSuspension">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/affectedDescription"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/cancellationDateTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/fromClassLevel"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/resumptionDateTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/suspensionType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/toClassLevel"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Class Suspension</rdfs:label>
        <skos:definition>Represents education operational disruptions.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/CommunicationLineDisruption -->

    <owl:Class rdf:about="https://sakuna.ph/CommunicationLineDisruption">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/affectedDescription"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/communicationStatus"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/interruptionDateTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/restorationDateTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/telecompany"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Communication Line Disruption</rdfs:label>
        <skos:definition>Represents impact on communication lines.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Country -->

    <owl:Class rdf:about="https://sakuna.ph/Country">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Location"/>
        <rdfs:label>Country</rdfs:label>
        <skos:definition>Administrative Level 0</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/DamageGeneral -->

    <owl:Class rdf:about="https://sakuna.ph/DamageGeneral">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:label xml:lang="en">Damage (General)</rdfs:label>
        <skos:definition>Represents general damage that does not fall under any sibling classes.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/DeclarationOfCalamity -->

    <owl:Class rdf:about="https://sakuna.ph/DeclarationOfCalamity">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Response"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/declarationType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/resolutionDate"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/resolutionNo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Declaration of Calamity</rdfs:label>
        <skos:definition>Represents events of state of calamity declaration.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/DisasterEvent -->

    <owl:Class rdf:about="https://sakuna.ph/DisasterEvent">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:label xml:lang="en">Disaster Event</rdfs:label>
        <skos:definition>Any event that has dealt notable impact to the population, infrastructure, or has disrupted operations and services.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/DisasterType -->

    <owl:Class rdf:about="https://sakuna.ph/DisasterType">
        <rdfs:label>Disaster Type</rdfs:label>
        <skos:definition>Disaster type based on the Emergency Events Database (EM-DAT) classification of disasters.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/DisasterTypeScheme -->

    <owl:Class rdf:about="https://sakuna.ph/DisasterTypeScheme"/>
    


    <!-- https://sakuna.ph/FlightDisruption -->

    <owl:Class rdf:about="https://sakuna.ph/FlightDisruption">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:label>Flight Disruption</rdfs:label>
        <skos:definition>Represents flight disruptions.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/HousingDamage -->

    <owl:Class rdf:about="https://sakuna.ph/HousingDamage">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/housingDamageAmount"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/partiallyDamagedHouses"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/totallyDamagedHouses"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Housing Damage</rdfs:label>
        <skos:definition>Represents impact on housing.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Impact -->

    <owl:Class rdf:about="https://sakuna.ph/Impact">
        <owl:disjointWith>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/DisasterEvent"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Location"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Preparedness"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Response"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:disjointWith>
        <rdfs:label xml:lang="en">Impact</rdfs:label>
        <skos:definition>Represents the impact of major or incident disasters.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Incident -->

    <owl:Class rdf:about="https://sakuna.ph/Incident">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/DisasterEvent"/>
        <owl:disjointWith rdf:resource="https://sakuna.ph/MajorEvent"/>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
        <skos:definition>A localized or small-scale disaster event, often reported at the municipal or barangay level and is related with a bigger, major event.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/InfrastructureDamage -->

    <owl:Class rdf:about="https://sakuna.ph/InfrastructureDamage">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/commercialDamageAmount"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/crossSectoralDamageAmount"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/infraDamageAmount"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/infraDamageClassification"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/infraDamageType"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/infraName"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/infraQtyDamaged"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/infraUnitDamaged"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/numberInfraDamaged"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/socialDamageAmount"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Infrastructure Damage</rdfs:label>
        <skos:definition>Represents impact on infrastructure.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/IslandGroup -->

    <owl:Class rdf:about="https://sakuna.ph/IslandGroup">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/isPartOf"/>
                <owl:someValuesFrom rdf:resource="https://sakuna.ph/Country"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Island Group</rdfs:label>
        <skos:definition>Represents island groups</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Location -->

    <owl:Class rdf:about="https://sakuna.ph/Location">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:label xml:lang="en">Location</rdfs:label>
        <skos:definition>Represents tiered locations (administrative levels) in the Philippines.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/MajorEvent -->

    <owl:Class rdf:about="https://sakuna.ph/MajorEvent">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/DisasterEvent"/>
        <rdfs:label xml:lang="en">Major</rdfs:label>
        <skos:definition>A large-scale or aggregated event spanning days that may encompass multiple locations and related incidents.</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/Municipality -->

    <owl:Class rdf:about="https://sakuna.ph/Municipality">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Location"/>
