            <owl:Restriction>
                <owl:onProperty rdf:resource="https://sakuna.ph/isPartOf"/>
                <owl:someValuesFrom rdf:resource="https://sakuna.ph/Province"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Municipality</rdfs:label>
        <skos:definition>Administrative Level 3</skos:definition>
    </owl:Class>
    


    <!-- https://sakuna.ph/PowerDisruption -->

    <owl:Class rdf:about="https://sakuna.ph/PowerDisruption">
        <rdfs:subClassOf rdf:resource="https://sakuna.ph/Impact"/>
