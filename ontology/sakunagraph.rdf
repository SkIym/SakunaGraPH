    </owl:Class>
    


    <!-- https://sakuna.ph/Response -->

    <owl:Class rdf:about="https://sakuna.ph/Response">
        <rdfs:label xml:lang="en">Response</rdfs:label>
        <skos:definition>Represents the responses taken to a disaster.</skos:definition>
    </owl:Class>
    


