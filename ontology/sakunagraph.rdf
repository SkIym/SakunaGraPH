    <!-- https://sakuna.ph/isPartOf -->

    <owl:ObjectProperty rdf:about="https://sakuna.ph/isPartOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/Barangay"/>
                    <rdf:Description rdf:about="https://sakuna.ph/IslandGroup"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Municipality"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Province"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Region"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/Country"/>
                    <rdf:Description rdf:about="https://sakuna.ph/IslandGroup"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Municipality"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Province"/>
                    <rdf:Description rdf:about="https://sakuna.ph/Region"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="en">is part of</rdfs:label>
    </owl:ObjectProperty>
    


