        <skos:definition>Indicates the end of the disaster.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterStart -->

    <owl:DatatypeProperty rdf:about="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterStart">
