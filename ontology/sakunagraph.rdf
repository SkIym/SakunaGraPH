                    <rdf:Description rdf:about="https://sakuna.ph/Response"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://sakuna.ph/Province"/>
        <rdfs:label xml:lang="en">has province</rdfs:label>
    </owl:ObjectProperty>
    


