    <!-- http://qudt.org/vocab/currency/PHP -->

    <owl:NamedIndividual rdf:about="http://qudt.org/vocab/currency/PHP"/>
    


    <!-- http://qudt.org/vocab/currency/USD -->

    <owl:NamedIndividual rdf:about="http://qudt.org/vocab/currency/USD"/>
    


    <!-- https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#NaturalDisasterType -->

    <owl:NamedIndividual rdf:about="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#NaturalDisasterType"/>
    


    <!-- https://sakuna.ph/Air -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Air">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Transport"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Transport accidents involving airplanes, helicopters, airships, and balloons.</skos:definition>
        <skos:note>Air: Transport accidents involving airplanes, helicopters, airships, and balloons.</skos:note>
        <skos:prefLabel xml:lang="en">Air</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/AnimalAccident -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/AnimalAccident">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Biological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Human encounters with dangerous or exotic animals in both urban and rural environments. </skos:definition>
        <skos:note>Animal accident: Human encounters with dangerous or exotic animals in both urban and rural environments.</skos:note>
        <skos:prefLabel xml:lang="en">Animal Accident</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ArmedConflict -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ArmedConflict">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Technological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Custom technological or man-made peril class to represent armed conflict events that deal impact to communities</skos:definition>
        <skos:note>Ambush/shooting, grenade/bombing incidents, can also involve civil disturbances, violence, and gun fires or armed scandals that can be due to national and local elections and holidays, for example. Often involves victims, killings, and results to deaths or injury.</skos:note>
        <skos:prefLabel xml:lang="en">Armed Conflict</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Ashfall -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Ashfall">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/VolcanicActivity"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Fine (less than 4 mm in diameter) unconsolidated volcanic debris blown into the atmosphere during an eruption; can remain airborne for long periods of time and travel considerable distance from the source.  </skos:definition>
        <skos:note>Ashfall: Fine (less than 4 mm in diameter) unconsolidated volcanic debris blown into the atmosphere during an eruption; can remain airborne for long periods of time and travel a considerable distance from the source.</skos:note>
        <skos:prefLabel xml:lang="en">Ashfall</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/AvalancheDry -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/AvalancheDry">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementDry"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Debris Avalanche: The sudden and very rapid downslope movement of a mixed mass of rock and soil. There are two general types of debris avalanches. A cold debris avalanche usually results from an unstable slope suddenly collapsing whereas a hot debris avalanche results from volcanic activity leading to slope instability and collapse.</skos:definition>
        <skos:note>Avalanche (dry): A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Debris Avalanche: The sudden and very rapid downslope movement of a mixed mass of rock and soil. There are two general types of debris avalanches. A cold debris avalanche usually results from an unstable slope suddenly collapsing whereas a hot debris avalanche results from volcanic activity leading to slope instability and collapse.</skos:note>
        <skos:prefLabel xml:lang="en">Avalanche (Dry)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/AvalancheWet -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/AvalancheWet">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementWet"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Snow Avalanche: Rapid downslope movement of a mix of snow and ice.</skos:definition>
        <skos:note>Avalanche (wet): A large mass of loosened earth material, snow, or ice that slides, flows, or falls rapidly down a mountainside under the force of gravity. Snow Avalanche: Rapid downslope movement of a mix of snow and ice.</skos:note>
        <skos:prefLabel xml:lang="en">Avalanche (Wet)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/BacterialDisease -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/BacterialDisease">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Epidemic"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>An unusual increase in the number of cases caused by exposure to bacteria either through skin contact, ingestion, or inhalation. Examples include salmonella, Methicillin-Resistant Staphylococcus Aureus (MRSA), and cholera, among others. </skos:definition>
        <skos:note>Bacterial disease: An unusual increase in the number of cases caused by exposure to bacteria either through skin contact, ingestion, or inhalation. Examples include salmonella, Methicillin-Resistant Staphylococcus Aureus (MRSA), gastroentritis due to unclean water, and cholera, pertussis, among others.</skos:note>
        <skos:prefLabel xml:lang="en">Bacterial Disease</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Biological -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Biological">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Natural"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/AnimalAccident"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Epidemic"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Infestation"/>
        <skos:definition>A hazard caused by exposure to living organisms and/or their toxic substances (e.g., venom, or mold) or vector-borne diseases that they may carry. Examples are venomous wildlife and insects, poisonous plants, algae blooms, and mosquitoes carrying agents that causes disease such as parasites, bacteria, or viruses (e.g., malaria).</skos:definition>
        <skos:prefLabel xml:lang="en">Biological</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/BlizzardStorm -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/BlizzardStorm">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A low-pressure system in winter months with significant accumulations of snow, freezing rain, sleet, or ice. A blizzard is a severe snowstorm with winds exceeding 35 mph (56 km/h) for three or more hours, producing reduced visibility (less than 0.25 miles (400 m)).</skos:definition>
        <skos:note>Blizzard storm: A low-pressure system in winter months with significant accumulations of snow, freezing rain, sleet, or ice. A blizzard is a severe snowstorm with winds exceeding 35 mph (56 km/h) for three or more hours, producing reduced visibility (less than 0.25 miles (400 m)).</skos:note>
        <skos:prefLabel xml:lang="en">Blizzard Storm</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ChemicalSpill -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ChemicalSpill">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Accident release occurring during the production, transportation, or handling of hazardous chemical substances.</skos:definition>
        <skos:note>Chemical spill: Accident release occurring during the production, transportation, or handling of hazardous chemical substances.</skos:note>
        <skos:prefLabel xml:lang="en">Chemical Spill</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Climatological -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Climatological">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Natural"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Drought"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Glacial"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Wildfire"/>
        <skos:definition>A hazard caused by long-lived, meso- to macro-scale atmospheric processes ranging from intra-seasonal to multi-decadal climate variability.</skos:definition>
        <skos:prefLabel xml:lang="en">Climatological</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/CoastalFlood -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/CoastalFlood">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Flood"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Higher-than-normal water levels along the coast caused by tidal changes or thunderstorms that result in flooding, which can last from days to weeks. </skos:definition>
        <skos:note>Coastal flood: Flood along the coast caused by tidal changes or storms. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas.</skos:note>
        <skos:prefLabel xml:lang="en">Coastal Flood</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ColdWave -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ColdWave">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/ExtremeTemperature"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A period of abnormally cold weather. Typically a cold wave lasts two or more days and may be aggravated by high winds. The exact temperature criteria for what constitutes a cold wave vary by location. </skos:definition>
        <skos:note>Cold wave: A period of abnormally cold weather. Typically, a cold wave lasts for two or more days and may be aggravated by high winds. The exact temperature criteria for what constitutes a cold wave may vary by location.</skos:note>
        <skos:prefLabel xml:lang="en">Cold Wave</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/CollapseIndustrial -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/CollapseIndustrial">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Accident involving the collapse of a building or structure. Can either involve industrial structures or domestic/non-industrial structures.</skos:definition>
        <skos:note>Collapse (industrial): Accident involving the fall or collapse of a building or structure. Can involve fallen industrial or commercial structures like billboards, towers, stores. Can be due to typhoons, ropical storms, tropical cyclones, tropical depressions.</skos:note>
        <skos:prefLabel xml:lang="en">Collapse (Industrial)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/CollapseMiscellaneous -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/CollapseMiscellaneous">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MiscellaneousAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Accident involving the collapse of a building or structure. Can either involve industrial structures or domestic/non-industrial structures.</skos:definition>
        <skos:note>Collapse of a building or structure. Can involve fallen debris, fallen tree/s, uprooted trees, toppled posts, and soil collapse. Can be due to typhoons, strong winds, tropical storms, tropical cyclones, tropical depressions.</skos:note>
        <skos:prefLabel xml:lang="en">Collapse (Misc)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Derecho -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Derecho">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Widespread and usually fast-moving windstorms associated with convection/convective storm. Derechos include downburst and straight-line winds. The damage from derechos is often confused with the damage from tornadoes. </skos:definition>
        <skos:note>Derecho: Windstorms associated with a convection. Derechos include downburst and straight-line winds.</skos:note>
        <skos:prefLabel xml:lang="en">Derecho</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/DisasterTypeScheme -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/DisasterTypeScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:hasTopConcept rdf:resource="https://sakuna.ph/Natural"/>
        <skos:hasTopConcept rdf:resource="https://sakuna.ph/Technological"/>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Drought -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Drought">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Climatological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>An extended period of unusually low precipitation that produces a shortage of water for people, animals, and plants. Drought is different from most other hazards in that it develops slowly, sometimes even over the years, and its onset is generally difficult to detect. Drought is not solely a physical phenomenon because its impacts can be exacerbated by human activities and water supply demands. Drought is therefore often defined both conceptually and operationally. Operational definitions of drought, i.e., the degree of precipitation reduction that constitutes a drought, vary by locality, climate, and environmental sector. </skos:definition>
        <skos:note>Drought: An extended period of unusually low precipitation that produces a shortage of water for people, animals, and plants. Drought is different from most other hazards in that it develops slowly, sometimes even over the years, and its onset is generally difficult to detect. Drought is not solely a physical phenomenon because its impacts can be exacerbated by human activities and water supply demands. Drought is therefore often defined both conceptually and operationally. Operational definitions of drought, i.e., the degree of precipitation reduction that constitutes a drought, vary by locality, climate, and environmental sector. Can be considered dry spell. Can be due to El Nino</skos:note>
        <skos:prefLabel xml:lang="en">Drought</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Earthquake -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Earthquake">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Geophysical"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/GroundMovement"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Tsunami"/>
        <skos:definition>Sudden movement of a block of the Earth&apos;s crust along a geological fault and associated ground shaking.</skos:definition>
        <skos:prefLabel xml:lang="en">Earthquake</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Epidemic -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Epidemic">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Biological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/BacterialDisease"/>
        <skos:narrower rdf:resource="https://sakuna.ph/FungalDisase"/>
        <skos:narrower rdf:resource="https://sakuna.ph/InfectiousDiseaseGeneral"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ParasiticDisease"/>
        <skos:narrower rdf:resource="https://sakuna.ph/PrionDisease"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ViralDisease"/>
        <skos:definition>Either an unusual, often sudden, increase in the number of cases of an infectious disease that already existed in the region (e.g., flu, or E. coli) or the appearance of an infectious disease previously absent from the region (e.g., plague, or polio).</skos:definition>
        <skos:prefLabel xml:lang="en">Epidemic</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ExplosionIndustrial -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ExplosionIndustrial">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Explosions involving buildings or structures. Can involve industrial structures</skos:definition>
        <skos:note>Explosion (industrial): Explosions involving buildings or structures. Can involve industrial structures like factories.</skos:note>
        <skos:prefLabel xml:lang="en">Explosion (Industrial)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ExplosionMiscellaneous -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ExplosionMiscellaneous">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MiscellaneousAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Explosions involving buildings or structures. Can involve industrial structures.</skos:definition>
        <skos:note>Explosion (miscellaneous): Non-industrial explosions involving buildings or structures. Grenade/bomb explosions. Can be due to elections and holidays.</skos:note>
        <skos:prefLabel xml:lang="en">Explosion (Misc)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Extraterrestrial -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Extraterrestrial">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Natural"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/SpaceImpact"/>
        <skos:narrower rdf:resource="https://sakuna.ph/SpaceWeather"/>
        <skos:definition>A hazard caused by asteroids, meteoroids, and comets as they pass near to the Earth, enter the Earth&apos;s atmosphere, and/or strike the Earth, and by changes in interplanetary conditions that effect the Earth&apos;s magnetosphere, ionosphere, and thermosphere.</skos:definition>
        <skos:prefLabel xml:lang="en">Extraterrestrial</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ExtratropicalStorm -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ExtratropicalStorm">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A type of low-pressure cyclonic system in the middle and high latitudes (also called mid-latitude cyclone) that primarily gets its energy from the horizontal temperature contrasts (fronts) in the atmosphere. When associated with cold fronts, extratropical cyclones may be particularly damaging (e.g., European winter/windstorm, Nor’easter). </skos:definition>
        <skos:note>Extratropical storm: A type of cyclonic system in the middle and high latitudes (also called a mid-latitude cyclone) that primarily gets its energy from the horizontal temperature contrasts (fronts) in the atmosphere. When associated with cold fronts, extra-tropical cyclones may be particularly damaging (e.g., European winter/windstorm, or Nor&apos;easter).</skos:note>
        <skos:prefLabel xml:lang="en">Extratropical Storm</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ExtremeTemperature -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ExtremeTemperature">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Meteorological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ColdWave"/>
        <skos:narrower rdf:resource="https://sakuna.ph/HeatWave"/>
        <skos:narrower rdf:resource="https://sakuna.ph/SevereWinterConditions"/>
        <skos:definition>A general term for temperature variations above (extreme heat) or below (extreme cold) normal conditions.</skos:definition>
        <skos:prefLabel xml:lang="en">Extreme Temperature</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/FireIndustrial -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/FireIndustrial">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Urban fire involving buildings or structures. Can involve industrial structures.</skos:definition>
        <skos:note>Fire (industrial): Fire incidents involving industrial buildings or structures. Can involve industrial structures like factories.</skos:note>
        <skos:prefLabel xml:lang="en">Fire (Industrial)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/FireMiscellaneous -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/FireMiscellaneous">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MiscellaneousAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Urban fire involving buildings or structures. Can involve industrial structures.</skos:definition>
        <skos:note>Fire (miscellaneous): Non-industrial fire incidents. Can involve residential structures.</skos:note>
        <skos:prefLabel xml:lang="en">Fire (Misc)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/FlashFlood -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/FlashFlood">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Flood"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Heavy or excessive rainfall in a short period of time that produce immediate runoff, creating flooding conditions within minutes or a few hours during or after the rainfall. </skos:definition>
        <skos:note>Flash flood: Heavy or excessive rainfall in a short period of time that produces immediate runoff, creating flooding conditions within minutes or a few hours during or after the rainfall. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas.</skos:note>
        <skos:prefLabel xml:lang="en">Flash Flood</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Flood -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Flood">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Hydrological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/CoastalFlood"/>
        <skos:narrower rdf:resource="https://sakuna.ph/FlashFlood"/>
        <skos:narrower rdf:resource="https://sakuna.ph/FloodGeneral"/>
        <skos:narrower rdf:resource="https://sakuna.ph/IceJamFlood"/>
        <skos:narrower rdf:resource="https://sakuna.ph/RiverineFlood"/>
        <skos:definition>A general term for the overflow of water from a stream channel onto normally dry land in the floodplain (riverine flooding), higher-than-normal levels along the coast (coastal flooding) and in lakes or reservoirs as well as ponding of water at or near the point where the rain fell (flash floods).</skos:definition>
        <skos:prefLabel xml:lang="en">Flood</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/FloodGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/FloodGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Flood"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A general term for the overflow of water from a stream channel onto normally dry land in the floodplain (riverine flooding), higher-than-normal levels along the coast (coastal flooding) and in lakes or reservoirs as well as ponding of water at or near the point where the rain fell (flash floods).</skos:definition>
        <skos:note>Flood (General): A general term for flooded areas (subsided, receding, or still flooded) or floodwaters and the overflow of water levels. Barangays and sitios affected, damaged and normally flooded in ft. Involves flooding in roads, zones, and areas in the country, affecting families and households. Can involve overflow or box of culverts, knee, waist, and gutter-deep levels of water. Sheet flooding. Can be due to heavy rains, monsoons, tropical storms, tropical cyclones, tropical depressions, and low pressure areas.</skos:note>
        <skos:prefLabel xml:lang="en">Flood (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Fog -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Fog">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Meteorological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Water droplets that are suspended in the air near the Earth’s surface. Fog is simply a cloud that is in contact with the ground. </skos:definition>
        <skos:note>Fog: Water droplets that are suspended in the air near the Earth&apos;s surface. Fog is, in fact, simply a cloud that is in contact with the ground.</skos:note>
        <skos:prefLabel xml:lang="en">Fog</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ForestFire -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ForestFire">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Wildfire"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A type of wildfire in a wooded area. </skos:definition>
        <skos:note>Forest Fire: A type of wildfire in a wooded area or forest. Can be due to El Nino.</skos:note>
        <skos:prefLabel xml:lang="en">Forest Fire</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/FungalDisase -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/FungalDisase">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Epidemic"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>An unusual increase in the number of cases caused by exposure to fungi either through skin contact, ingestion, or inhalation of spores. Examples are fungal pneumonia, fungal meningitis, etc.</skos:definition>
        <skos:note>Fungal Disease: An unusual increase in the number of cases caused by exposure to fungi either through skin contact, ingestion, or inhalation of spores. Examples are fungal pneumonia, fungal meningitis, etc.</skos:note>
        <skos:prefLabel>Fungal Disease</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/GasLeak -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/GasLeak">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Gas leak incidents.</skos:definition>
        <skos:note>Gas leak incidents.</skos:note>
        <skos:prefLabel xml:lang="en">Gas Leak</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Geophysical -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Geophysical">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Natural"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Earthquake"/>
        <skos:narrower rdf:resource="https://sakuna.ph/MassMovementDry"/>
        <skos:narrower rdf:resource="https://sakuna.ph/VolcanicActivity"/>
        <skos:definition>A hazard originating from solid earth. This term is used interchangeably with the term geological hazard.</skos:definition>
        <skos:prefLabel xml:lang="en">Geophysical</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Glacial -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Glacial">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Climatological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:altLabel>Glacial Lake Outburst</skos:altLabel>
        <skos:definition>A flood that occurs when water dammed by a glacier or moraine is suddenly released. Glacial lakes can be at the front of the glacier (marginal lake) or below the ice sheet (sub-glacial lake).  </skos:definition>
        <skos:note>Glacial: Occurs when water held back by a glacier or moraine is suddenly released. Glacial lakes can be at the front of the glacier (marginal lake) or below the ice sheet (sub-glacial lake).</skos:note>
        <skos:prefLabel xml:lang="en">Glacial</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/GrasshopperInfestation -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/GrasshopperInfestation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Infestation"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Infestation of grasshoppers (insects).</skos:definition>
        <skos:note>Infestation of grasshoppers (insects).</skos:note>
        <skos:prefLabel xml:lang="en">Grasshopper Infestation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/GroundMovement -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/GroundMovement">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Earthquake"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Surface displacement of earthen materials due to ground shaking triggered by earthquakes or volcanic eruptions. </skos:definition>
        <skos:note>Ground movement: Surface displacement of earthen materials due to ground shaking triggered by earthquakes or volcanic eruptions. Often described with magnitudes, intensities, and epicenters.</skos:note>
        <skos:prefLabel xml:lang="en">Ground Movement</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Hail -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Hail">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Solid precipitation in the form of irregular pellets or balls of ice more than 5 mm in diameter. </skos:definition>
        <skos:note>Hail: Solid precipitation in the form of irregular pellets or balls of ice more than 5 mm in diameter.</skos:note>
        <skos:prefLabel xml:lang="en">Hail</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/HeatWave -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/HeatWave">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/ExtremeTemperature"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A period of abnormally hot and/or unusually humid weather. Typically a heat wave lasts two or more days. The exact temperature criteria for what constitutes a heat wave vary by location.  </skos:definition>
        <skos:note>Heat wave: A period of abnormally hot and/or unusually humid weather. Typically, a heat wave lasts for two or more days. The exact temperature criteria for what constitutes a heat wave may vary by location.</skos:note>
        <skos:prefLabel xml:lang="en">Heat Wave</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Hydrological -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Hydrological">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Natural"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Flood"/>
        <skos:narrower rdf:resource="https://sakuna.ph/MassMovementWet"/>
        <skos:narrower rdf:resource="https://sakuna.ph/WaveAction"/>
        <skos:definition>A hazard caused by the occurrence, movement, and distribution of surface and subsurface freshwater and saltwater.</skos:definition>
        <skos:prefLabel xml:lang="en">Hydrological</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/IceJamFlood -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/IceJamFlood">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Flood"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>The accumulation of floating ice restricting or blocking a river’s flow and drainage. Ice jams tend to develop near river bends and obstructions (e.g., bridges).  </skos:definition>
        <skos:note>Ice Jam: The accumulation of floating ice restricting or blocking a river&apos;s flow and drainage. Ice jams tend to develop near river bends and obstructions (e.g., bridges).</skos:note>
        <skos:prefLabel xml:lang="en">Ice Jam Flood</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/IndustrialAccident -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/IndustrialAccident">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Technological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ChemicalSpill"/>
        <skos:narrower rdf:resource="https://sakuna.ph/CollapseIndustrial"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ExplosionIndustrial"/>
        <skos:narrower rdf:resource="https://sakuna.ph/FireIndustrial"/>
        <skos:narrower rdf:resource="https://sakuna.ph/GasLeak"/>
        <skos:narrower rdf:resource="https://sakuna.ph/IndustrialAccidentGeneral"/>
        <skos:narrower rdf:resource="https://sakuna.ph/OilSpill"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Poisoning"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Radiation"/>
        <skos:definition>Disaster type term used in EM-DAT to describe technological accidents of an industrial nature/involving industrial buildings (e.g. factories).</skos:definition>
        <skos:prefLabel xml:lang="en">Industrial Accident</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/IndustrialAccidentGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/IndustrialAccidentGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Disaster type term used in EM-DAT to describe technological accidents of an industrial nature/involving industrial buildings (e.g. factories).</skos:definition>
        <skos:note>Industrial accident (general): Any form of general industrial accidents.</skos:note>
        <skos:prefLabel xml:lang="en">Industrial Accident (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/InfectiousDiseaseGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/InfectiousDiseaseGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Epidemic"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Either an unusual, often sudden, increase in the number of cases of an infectious disease that already existed in the region (e.g., flu, or E. coli) or the appearance of an infectious disease previously absent from the region (e.g., plague, or polio).</skos:definition>
        <skos:note>Infectious disease (general): Either an unusual, often sudden, increase in the number of cases or outbreak of an infectious disease that already existed in the region (e.g., flu, or E. coli, gastroentritis or the appearance of an infectious disease previously absent from the region (e.g., plague, or polio).</skos:note>
        <skos:prefLabel xml:lang="en">Infectious Disease (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Infestation -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Infestation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Biological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/GrasshopperInfestation"/>
        <skos:narrower rdf:resource="https://sakuna.ph/InfestationGeneral"/>
        <skos:narrower rdf:resource="https://sakuna.ph/LocustInfestation"/>
        <skos:narrower rdf:resource="https://sakuna.ph/WormsInfestation"/>
        <skos:definition>The pervasive influx, swarming and/or hatching of insects, worms, or other animals affecting humans, animals, crops, and perishable goods.</skos:definition>
        <skos:prefLabel xml:lang="en">Infestation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/InfestationGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/InfestationGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Infestation"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>The pervasive influx, swarming and/or hatching of insects, worms, or other animals affecting humans, animals, crops, and perishable goods.</skos:definition>
        <skos:note>Infestation (general): The pervasive influx, swarming and/or hatching of insects, worms, or other animals affecting humans, animals, crops, and perishable goods.</skos:note>
        <skos:prefLabel xml:lang="en">Infestation (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Lahar -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Lahar">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/VolcanicActivity"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Hot or cold mixture of earthen material flowing on the slope of a volcano either during or between volcanic eruptions. </skos:definition>
        <skos:note>Lahar: Hot or cold mixture of earthen material flowing down the slope of a volcano either during or between volcanic eruptions.</skos:note>
        <skos:prefLabel xml:lang="en">Lahar</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/LandFire -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/LandFire">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Wildfire"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A type of wildfire in a brush, bush, pasture, grassland, or other treeless natural environment.</skos:definition>
        <skos:note>Land Fire: A type of wildfire in a brush, bush, pasture, grassland, or other treeless natural environment. Can be due to El Nino.</skos:note>
        <skos:prefLabel xml:lang="en">Land Fire</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/LandslideDry -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/LandslideDry">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementDry"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Any kind of moderate to rapid soil movement incl. lahars, mudslides, and debris flows (under dry conditions). A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face.</skos:definition>
        <skos:note>Landslide (dry): Any kind of moderate to rapid soil movement, can be and often induced by an earthquake (under dry conditions) bringing damage. A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face. Often due to earthquakes and affecting houses.</skos:note>
        <skos:prefLabel xml:lang="en">Landslide (Dry)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/LandslideWet -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/LandslideWet">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementWet"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Any kind of moderate to rapid soil movement incl. lahars, mudslides, and debris flows (under wet conditions). A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face.</skos:definition>
        <skos:note>Landslide (wet): Any kind of moderate to rapid soil movement, can be induced by rain (under wet conditions) bringing damage. Can be due to tropical cyclones, stroms, depressions. A landslide is the movement of soil or rock controlled by gravity and the speed of the movement usually ranges between slow and rapid, but it is not very slow. It can be superficial or deep, but the materials must make up a mass that is a portion of the slope or the slope itself. The movement has to be downward and outward with a free face.  Often due to rain and affecting houses.</skos:note>
        <skos:prefLabel xml:lang="en">Landslide (Wet)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/LavaFlow -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/LavaFlow">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/VolcanicActivity"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>The ejected magma that moves as a liquid mass downslope from a volcano during an eruption. </skos:definition>
        <skos:note>Lava Flow: The ejected magma that moves as a liquid mass downslope from a volcano during an eruption.</skos:note>
        <skos:prefLabel xml:lang="en">Lava Flow</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/LocustInfestation -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/LocustInfestation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Infestation"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Infestation of locusts (insects).</skos:definition>
        <skos:note>Infestation of locusts (insects).</skos:note>
        <skos:prefLabel xml:lang="en">Locust Infestation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/MassMovementDry -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/MassMovementDry">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Geophysical"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/AvalancheDry"/>
        <skos:narrower rdf:resource="https://sakuna.ph/LandslideDry"/>
        <skos:narrower rdf:resource="https://sakuna.ph/RockfallDry"/>
        <skos:narrower rdf:resource="https://sakuna.ph/SuddenSubsidenceDry"/>
        <skos:definition>Any type of downslope movement of earth materials under hydrological dry conditions.</skos:definition>
        <skos:prefLabel xml:lang="en">Mass Movement (Dry)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/MassMovementWet -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/MassMovementWet">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Hydrological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/AvalancheWet"/>
        <skos:narrower rdf:resource="https://sakuna.ph/LandslideWet"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Mudslide"/>
        <skos:narrower rdf:resource="https://sakuna.ph/RockfallWet"/>
        <skos:narrower rdf:resource="https://sakuna.ph/SuddenSubsidenceWet"/>
        <skos:definition>Types of mass movement that occur when heavy rain or rapid snow/ice melt send large amounts of vegetation, mud, or rock down a slope driven by gravitational forces.</skos:definition>
        <skos:prefLabel xml:lang="en">Mass Movement (Wet)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Meteorological -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Meteorological">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Natural"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ExtremeTemperature"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Fog"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Storm"/>
        <skos:definition>A hazard caused by short-lived, micro- to meso-scale extreme weather and atmospheric conditions that last from minutes to days.</skos:definition>
        <skos:prefLabel xml:lang="en">Meteorological</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/MiscellaneousAccident -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/MiscellaneousAccident">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Technological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/CollapseMiscellaneous"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ExplosionMiscellaneous"/>
        <skos:narrower rdf:resource="https://sakuna.ph/FireMiscellaneous"/>
        <skos:narrower rdf:resource="https://sakuna.ph/MiscellaneousAccidentGeneral"/>
        <skos:definition>Disaster type term used in EM-DAT to describe technological accidents of a non-industrial or transport nature (e.g., involving houses).</skos:definition>
        <skos:prefLabel xml:lang="en">Miscellaneous Accident</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/MiscellaneousAccidentGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/MiscellaneousAccidentGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MiscellaneousAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Disaster type term used in EM-DAT to describe technological accidents of a non-industrial or transport nature (e.g., involving houses).</skos:definition>
        <skos:note>Miscellaneous accident (general): Can involve fireworks or firework-related incidents (injuries) or events about elections, celebrations (year-end, christmas), observance of holidays (such as the Lenten season, Undas, All Saints&apos; Day and All Soul&apos;s Day). Can involve drowning incidents and food poisoning. Does not include transport or vehicular accidents.</skos:note>
        <skos:prefLabel xml:lang="en">Miscellaneous Accident (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Mudslide -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Mudslide">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementWet"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A form of mass wasting involving fast-moving flow of debris and dirt that has become liquified by the addition of water.</skos:definition>
        <skos:note>Mudslide: A form of mass wasting involving fast-moving flow of debris and dirt that has become liquified by the addition of water. Also called a mudflow. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas.</skos:note>
        <skos:prefLabel xml:lang="en">Mudslide</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Natural -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Natural">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:closeMatch rdf:resource="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#NaturalDisasterType"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Biological"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Climatological"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Extraterrestrial"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Geophysical"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Hydrological"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Meteorological"/>
        <skos:topConceptOf rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Naturally occurring disastrous events</skos:definition>
        <skos:prefLabel xml:lang="en">Natural</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/OilSpill -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/OilSpill">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Accident release occurring during the production, transportation, or handling of oil.</skos:definition>
        <skos:note>Oil spill: Accident release occurring during the production, transportation, or handling of oil.</skos:note>
        <skos:prefLabel xml:lang="en">Oil Spill</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/PHP_millions -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/PHP_millions">
        <rdf:type rdf:resource="http://qudt.org/schema/qudt/CurrencyUnit"/>
        <skos:broader rdf:resource="http://qudt.org/vocab/currency/PHP"/>
        <qudt:conversionMultiplier rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1000000</qudt:conversionMultiplier>
        <qudt:conversionOffset rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</qudt:conversionOffset>
        <qudt:hasQuantityKind rdf:resource="http://qudt.org/vocab/quantitykind/Currency"/>
        <rdfs:label xml:lang="en">Philippine Peso (millions)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ParasiticDisease -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ParasiticDisease">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Epidemic"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>An unusual increase in the number of cases caused by exposure to a parasite, i.e., an organism living on or in a host. Exposure to parasites occurs mostly through contaminated water, food, or contact with insects, animals, etc. Examples are malaria, Chagas disease, giardiasis, and Trichinellosis.</skos:definition>
        <skos:note>Parasitic disease: An unusual increase in the number of cases caused by exposure to a parasite, i.e., an organism living on or in a host. Exposure to parasites occurs mostly through contaminated water, food, or contact with insects, animals, etc. Examples are malaria, Chagas disease, giardiasis, and Trichinellosis.</skos:note>
        <skos:prefLabel xml:lang="en">Parasitic Disease</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Poisoning -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Poisoning">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Poisoning of atmosphere or water courses due to industrial sources of contamination.</skos:definition>
        <skos:note>Poisoning of atmosphere or water courses due to industrial sources of contamination.</skos:note>
        <skos:prefLabel xml:lang="en">Poisoning</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/PrionDisease -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/PrionDisease">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Epidemic"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A type of biological hazard caused by prion proteins. Prion diseases or transmissible spongiform encephalopathies (TSEs) are a family of rare progressive neurodegenerative disorders that affect both humans and animals. They are characterized by long incubation periods and neural loss. Examples are Bovine Spongiform Encephalopathy (BSE), Creutzfeldt-Jakob Disease (CJD), Kuru, etc.</skos:definition>
        <skos:note>Prion disease: A type of biological hazard caused by prion proteins. Prion diseases or transmissible spongiform encephalopathies (TSEs) are a family of rare progressive neurodegenerative disorders that affect both humans and animals. They are characterized by long incubation periods and neural loss. Examples are Bovine Spongiform Encephalopathy (BSE), Creutzfeldt-Jakob Disease (CJD), Kuru, etc.</skos:note>
        <skos:prefLabel xml:lang="en">Prion Disease</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/PyroclasticFlow -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/PyroclasticFlow">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/VolcanicActivity"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Extremely hot gases, ash, and other materials of more than 1,000 degrees Celsius that rapidly flow down the flank of a volcano (more than 700 km/h) during an eruption.  </skos:definition>
        <skos:note>Pyroclastic Flow: Extremely hot gases, ash, and other materials with a temperature of more than 1,000 degrees Celsius that rapidly flow down the flank of a volcano (at more than 700 km/h) during an eruption.</skos:note>
        <skos:prefLabel xml:lang="en">Pyroclastic Flow</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Radiation -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Radiation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Exposure to harmful radiation or reactive substances.</skos:definition>
        <skos:note>Radiation: Exposure to harmful radiation or reactive substances.</skos:note>
        <skos:prefLabel xml:lang="en">Radiation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Rail -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Rail">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Transport"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Transport accidents involving trains.</skos:definition>
        <skos:note>Rail: Transport accidents involving trains.</skos:note>
        <skos:prefLabel xml:lang="en">Rail</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/RiverineFlood -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/RiverineFlood">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Flood"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A type of flooding resulting from the overflow of water from a stream or river channel onto normally dry land in the floodplain adjacent to the channel.</skos:definition>
        <skos:note>Riverine flood: A type of flooding resulting due to the river (swollen river) or overflowing of a stream, creek, or  channel onto normally dry land in the floodplain adjacent to the channel.</skos:note>
        <skos:prefLabel xml:lang="en">Riverine Flood</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Road -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Road">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Transport"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Transport accidents involving motor vehicles on roads and tracks.</skos:definition>
        <skos:note>Road: Transport or vehicular accidents involving motor vehicles on roads and tracks. Can be due to heavy rainfall, earthquakes, or certain special events like holidays. Can involve road cuts and collisions.</skos:note>
        <skos:prefLabel xml:lang="en">Road</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/RockfallDry -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/RockfallDry">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementDry"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A quantity of rock that has fallen from a cliff face or from the roof or walls of mine or quarry workings under dry conditions.</skos:definition>
        <skos:note>Rockfall (dry): A quantity of rock that has fallen from a cliff face or from the roof or walls of mine or quarry workings under dry conditions. Also called rock slide under dry conditions. Can be due to earthquakes. Can occur near roads.</skos:note>
        <skos:prefLabel xml:lang="en">Rockfall (Dry)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/RockfallWet -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/RockfallWet">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementWet"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A quantity of rock or boulders that has fallen from a cliff face, mountain or from the roof or walls of mine or quarry workings under wet conditions or rain.</skos:definition>
        <skos:note>Rockfall (wet): A quantity of rock or boulders that has fallen from a cliff face, mountain or from the roof or walls of mine or quarry workings under wet conditions or rain. Also called rock slide under wet conditions. Can be due to tropical cyclones, tropical storms, tropical depressions, shear line, monsoons. Sometimes reported to hit structures.</skos:note>
        <skos:prefLabel xml:lang="en">Rockfall (Wet)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/RogueWave -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/RogueWave">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/WaveAction"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>An unusual single crest of an ocean wave far out at sea that is much higher and/or steeper than other waves in the prevailing swell system. </skos:definition>
        <skos:note>Rouge wave: An unusual single crest of an ocean wave far out at sea that is much higher and/or steeper than other waves in the prevailing swell system.</skos:note>
        <skos:prefLabel xml:lang="en">Rogue Wave</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/SandStorm -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/SandStorm">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Strong winds carry particles of sand aloft, but generally confined to less than 50 feet (15 m), especially common in arid and semi-arid environments. A dust storm is also characterised by strong winds but carries smaller particles of dust rather than sand over an extensive area. </skos:definition>
        <skos:note>Sand storm: Strong winds carrying particles of sand aloft, but generally confined to less than 50 feet (15 m), especially common in arid and semi-arid environments. A dust storm is also characterized by strong winds but carries smaller particles of dust rather than sand over an extensive area.</skos:note>
        <skos:prefLabel xml:lang="en">Sand Storm</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Seiche -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Seiche">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/WaveAction"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A standing wave of water in a large semi- or fully-enclosed body of water (lakes or bays) created by strong winds and/or a large barometric pressure gradient. </skos:definition>
        <skos:note>Seiche: A standing wave of water in a large semi- or fully-enclosed body of water (lakes or bays) created by strong winds and/or a large barometric pressure gradient.</skos:note>
        <skos:prefLabel xml:lang="en">Seiche</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/SevereWeather -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/SevereWeather">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Severe weather, heavy rains and strong winds bringing damage.</skos:definition>
        <skos:note>Severe weather, heavy rains and strong winds bringing damage.</skos:note>
        <skos:prefLabel xml:lang="en">Severe Weather</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/SevereWinterConditions -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/SevereWinterConditions">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/ExtremeTemperature"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Damage caused by snow and ice. Winter damage refers to damage to buildings, infrastructure, traffic (esp. navigation) inflicted by snow and ice in the form of snow pressure, freezing rain, frozen waterways etc.</skos:definition>
        <skos:note>Severe winter conditions: Damage caused by snow and ice. Winter damage refers to damage to buildings, infrastructure, traffic (esp. navigation) inflicted by snow and ice in the form of snow pressure, freezing rain, frozen waterways etc.</skos:note>
        <skos:prefLabel xml:lang="en">Severe Winter Conditions</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/SpaceImpact -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/SpaceImpact">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Extraterrestrial"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A type of extra-terrestrial hazard caused by the collision a meteoroid, asteroid, or comet with the Earth.</skos:definition>
        <skos:note>Space impact: A type of extra-terrestrial hazard caused by the collision a meteoroid, asteroid, or comet with the Earth.</skos:note>
        <skos:prefLabel xml:lang="en">Space Impact</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/SpaceWeather -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/SpaceWeather">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Extraterrestrial"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A general term for extraterrestrial weather conditions driven by solar eruptions such as geomagnetic storms, radio disturbances, and solar energetic particles. </skos:definition>
        <skos:note>Space weather: A general term for extra-terrestrial weather conditions driven by solar eruptions such as geomagnetic storms, radio disturbances, and solar energetic particles.</skos:note>
        <skos:prefLabel xml:lang="en">Space Weather</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Storm -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Storm">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Meteorological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/BlizzardStorm"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Derecho"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ExtratropicalStorm"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Hail"/>
        <skos:narrower rdf:resource="https://sakuna.ph/SandStorm"/>
        <skos:narrower rdf:resource="https://sakuna.ph/SevereWeather"/>
        <skos:narrower rdf:resource="https://sakuna.ph/StormGeneral"/>
        <skos:narrower rdf:resource="https://sakuna.ph/StormSurge"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Thunderstorms"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Tornado"/>
        <skos:narrower rdf:resource="https://sakuna.ph/TropicalCyclone"/>
        <skos:definition>Can be weather disturbances brought by monsoons (southwest or northeast monsoons), low pressure areas and shear lines that can bring effects like flooding, flashfloods, thunderstorms, and heavy rains.</skos:definition>
        <skos:prefLabel xml:lang="en">Storm</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/StormGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/StormGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Can be weather disturbances brought by monsoons (southwest or northeast monsoons), low pressure areas and shear lines that can bring effects like flooding, flashfloods, thunderstorms, and heavy rains.</skos:definition>
        <skos:note>Storm general: Can be storms brought by monsoons (southwest or northeast monsoons), low pressure areas and shear lines that can bring effects like flooding, flashfloods, thunderstorms, and heavy rains.</skos:note>
        <skos:prefLabel xml:lang="en">Storm (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/StormSurge -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/StormSurge">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>An abnormal rise in sea level generated by a tropical cyclone or other intense storms. </skos:definition>
        <skos:note>Storm Surge: An abnormal surge or rise in sea level. Can be due to tropical storms, tropical cyclones, tropical depressions, heavy rain, or low pressure areas.</skos:note>
        <skos:prefLabel xml:lang="en">Storm Surge</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/SuddenSubsidenceDry -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/SuddenSubsidenceDry">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementDry"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Sinking of the ground due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under dry conditions as a result of a geophysical trigger. </skos:definition>
        <skos:note>Sudden subsidence (dry): Sinking of the ground due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under dry conditions as a result of a geophysical trigger. Can involve liquefaction and can be due to earthquakes.</skos:note>
        <skos:prefLabel xml:lang="en">Sudden Subsidence (Dry)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/SuddenSubsidenceWet -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/SuddenSubsidenceWet">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/MassMovementWet"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Sinking of the ground due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under wet conditions as a result of a hydrological trigger (e.g., rain). </skos:definition>
        <skos:note>Sudden subsidence (wet): Sinking of the ground like liquefaction near rivers or seas due to groundwater removal, mining, dissolution of limestone (e.g., karst sinkholes), extraction of natural gas, and earthquakes. In this case, the sinking occurs under wet conditions as a result of a hydrological trigger (e.g., rain). Can be due to tropical cyclones, stroms, depressions as well.</skos:note>
        <skos:prefLabel xml:lang="en">Sudden Subsidence (Wet)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Technological -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Technological">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ArmedConflict"/>
        <skos:narrower rdf:resource="https://sakuna.ph/IndustrialAccident"/>
        <skos:narrower rdf:resource="https://sakuna.ph/MiscellaneousAccident"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Transport"/>
        <skos:topConceptOf rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Man-made events causing impact and technological incidents.</skos:definition>
        <skos:example>Armed conflict, chemical spill, or industrial fires.</skos:example>
        <skos:prefLabel xml:lang="en">Technological</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Thunderstorms -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Thunderstorms">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A high-voltage, visible electrical discharge produced by a thunderstorm and followed by the sound of thunder.</skos:definition>
        <skos:note>Thunderstorms: Lightnings produced by a thunderstorm and followed by the sound of thunder.</skos:note>
        <skos:prefLabel xml:lang="en">Thunderstorms</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Tornado -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Tornado">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A violently rotating column of air that reaches the ground or open water (waterspout). </skos:definition>
        <skos:note>Tornado: Tornadoes and whirlwinds. A violently rotating column of air that reaches the ground or open water (waterspout). Can be associated with heavy rains and bring damage.</skos:note>
        <skos:prefLabel xml:lang="en">Tornado</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Transport -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Transport">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Technological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Air"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Rail"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Road"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Water"/>
        <skos:definition>Disaster type term used to describe technological transport accidents involving mechanized modes of transport. It comprises four disaster subtypes (i.e., Air, Water, Rail, and Road).</skos:definition>
        <skos:prefLabel xml:lang="en">Transport</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/TropicalCyclone -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/TropicalCyclone">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Storm"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A tropical cyclone originates over tropical or subtropical waters. It is characterised by a warm-core, non-frontal synoptic-scale cyclone with a low pressure centre, spiral rain bands and strong winds. Depending on their location, tropical cyclones are referred to as hurricanes (Atlantic, Northeast Pacific), typhoons (Northwest Pacific), or cyclones (South Pacific and Indian Ocean). </skos:definition>
        <skos:note>Tropical Cyclone: Can be called typhoons, super typhoons, tropical storms, tropical depressions, and low pressure areas. Sometimes called TS, TC, TD, LPA plus the name. It is characterized by a warm-core, non-frontal synoptic-scale cyclone with a low-pressure center, spiral rain bands and strong winds. Depending on their location, tropical cyclones are referred to as hurricanes (Atlantic, Northeast Pacific), typhoons (Northwest Pacific), or cyclones (South Pacific and Indian Ocean). A tropical cyclone originates over tropical or subtropical waters.</skos:note>
        <skos:prefLabel xml:lang="en">Tropical Cyclone</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Tsunami -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Tsunami">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Earthquake"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A series of waves (with long wavelengths when traveling across the deep ocean) that are generated by a displacement of massive amounts of water through underwater earthquakes, volcanic eruptions or landslides. Tsunami waves travel at very high speed across the ocean but as they begin to reach shallow water they slow down and the wave grows steeper. </skos:definition>
        <skos:note>Tsunami: A series of waves (with long wavelengths when traveling across the deep ocean) that are generated by a displacement of massive amounts of water through underwater earthquakes, volcanic eruptions, or landslides. Tsunami waves travel at very high speed across the ocean, but as they begin to reach shallow water they slow down, and the wave grows steeper.</skos:note>
        <skos:prefLabel xml:lang="en">Tsunami</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/USD_thousands -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/USD_thousands">
        <rdf:type rdf:resource="http://qudt.org/schema/qudt/CurrencyUnit"/>
        <skos:broader rdf:resource="http://qudt.org/vocab/currency/USD"/>
        <qudt:conversionMultiplier rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1000</qudt:conversionMultiplier>
        <qudt:conversionOffset rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</qudt:conversionOffset>
        <qudt:hasQuantityKind rdf:resource="http://qudt.org/vocab/quantitykind/Currency"/>
        <rdfs:label xml:lang="en">US Dollar (thousands)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/ViralDisease -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/ViralDisease">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Epidemic"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>An unusual increase in the number of cases caused by exposure to virus either through skin contact, ingestion, or inhalation.</skos:definition>
        <skos:note>Viral disease: An unusual increase in the number of cases caused by exposure to virus either through skin contact, ingestion, or inhalation. Common viral illnesses include colds, the flu, COVID-19, norovirus (&quot;stomach flu&quot;), HPV (warts) and herpes simplex virus (cold sores)</skos:note>
        <skos:prefLabel xml:lang="en">Viral Disease</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/VolcanicActivity -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/VolcanicActivity">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Geophysical"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Ashfall"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Lahar"/>
        <skos:narrower rdf:resource="https://sakuna.ph/LavaFlow"/>
        <skos:narrower rdf:resource="https://sakuna.ph/PyroclasticFlow"/>
        <skos:narrower rdf:resource="https://sakuna.ph/VolcanicActivityGeneral"/>
        <skos:definition>A type of volcanic event near an opening/vent in the Earth&apos;s surface including volcanic eruptions of lava, ash, hot vapor, gas, and pyroclastic material.</skos:definition>
        <skos:prefLabel xml:lang="en">Volcanic Activity</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/VolcanicActivityGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/VolcanicActivityGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/VolcanicActivity"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>A type of volcanic event near an opening/vent in the Earth’s surface including volcanic eruptions of lava, ash, hot vapor, gas, and pyroclastic material.</skos:definition>
        <skos:note>Volcanic activity (general): A type of volcanic event near an opening/vent in the Earth&apos;s surface including volcanic eruptions of lava, ash, hot vapor, gas, and pyroclastic material. Explosive eruptions in volcanoes.</skos:note>
        <skos:prefLabel xml:lang="en">Volcanic Activity (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Water -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Water">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Transport"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Transport accidents involving sailing boats, ferries, cruise ships, and other vessels.</skos:definition>
        <skos:note>Water: Transport or maritime accidents or incidents involving sailing boats (motorbancas), ferries, cruise ships, and other vessels. Can be due to weather conditions, strong winds, typhoons, tropical storms, cyclones, and depressions.</skos:note>
        <skos:prefLabel>Water</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/WaveAction -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/WaveAction">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Hydrological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/RogueWave"/>
        <skos:narrower rdf:resource="https://sakuna.ph/Seiche"/>
        <skos:narrower rdf:resource="https://sakuna.ph/WaveActionGeneral"/>
        <skos:definition>Wind-generated surface waves that can occur on the surface of any open body of water such as oceans, rivers and lakes, etc. The size of the wave depends on the strength of the wind and the traveled distance (fetch).</skos:definition>
        <skos:prefLabel xml:lang="en">Wave Action</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/WaveActionGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/WaveActionGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/WaveAction"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Wind-generated surface waves that can occur on the surface of any open body of water such as oceans, rivers and lakes, etc. The size of the wave depends on the strength of the wind and the traveled distance (fetch).</skos:definition>
        <skos:note>Wave action (general): Wind-generated surface big waves that can occur near coastal areas or on the surface of any open body of water such as oceans, rivers, or lakes. The size of the wave depends on the strength of the wind and the distance traveled (fetch).</skos:note>
        <skos:prefLabel>Wave Action (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/Wildfire -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/Wildfire">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Climatological"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:narrower rdf:resource="https://sakuna.ph/ForestFire"/>
        <skos:narrower rdf:resource="https://sakuna.ph/LandFire"/>
        <skos:narrower rdf:resource="https://sakuna.ph/WildfireGeneral"/>
        <skos:definition>Any uncontrolled and non-prescribed combustion or burning of plants in a natural setting such as a forest, grassland, brush land or tundra, which consumes natural fuels and spreads based on environmental conditions (e.g., wind, or topography). Wildfires can be triggered by lightning or human actions.</skos:definition>
        <skos:prefLabel xml:lang="en">Wildfire</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://sakuna.ph/WildfireGeneral -->

    <owl:NamedIndividual rdf:about="https://sakuna.ph/WildfireGeneral">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://sakuna.ph/DisasterType"/>
        <skos:broader rdf:resource="https://sakuna.ph/Wildfire"/>
        <skos:inScheme rdf:resource="https://sakuna.ph/DisasterTypeScheme"/>
        <skos:definition>Any uncontrolled and non-prescribed combustion or burning of plants in a natural setting such as a forest, grassland, brush land or tundra, which consumes natural fuels and spreads based on environmental conditions (e.g., wind, or topography). Wildfires can be triggered by lightning or human actions.</skos:definition>
        <skos:note>Wildfire (general): Any type of fire  in a natural setting such as a grassland, mountain, brush land or tundra, which consumes natural fuels such as tress and spreads based on environmental conditions (e.g., wind, or topography). Wildfires can be triggered by lightning or human actions. Can affect animals, trees, and properties. Can be due to El Nino.</skos:note>
        <skos:prefLabel xml:lang="en">Wildfire (General)</skos:prefLabel>
    </owl:NamedIndividual>
    


