    <!-- https://sakuna.ph/affectedDescription -->

    <owl:DatatypeProperty rdf:about="https://sakuna.ph/affectedDescription">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://sakuna.ph/AirportDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/ClassSuspension"/>
                    <rdf:Description rdf:about="https://sakuna.ph/CommunicationLineDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/PowerDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/RoadAndBridgesDamage"/>
                    <rdf:Description rdf:about="https://sakuna.ph/SeaportDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/WaterDisruption"/>
                    <rdf:Description rdf:about="https://sakuna.ph/WorkSuspension"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>affected description</rdfs:label>
        <skos:definition>General (unprocessed) information about the affected entity.</skos:definition>
    </owl:DatatypeProperty>
    


