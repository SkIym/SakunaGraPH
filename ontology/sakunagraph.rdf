    <!-- https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterEnd -->

    <owl:DatatypeProperty rdf:about="https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterEnd">
        <owl:equivalentProperty rdf:resource="https://sakuna.ph/endDate"/>
        <rdfs:domain rdf:resource="https://sakuna.ph/DisasterEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
