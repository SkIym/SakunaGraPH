    <owl:ObjectProperty rdf:about="https://sakuna.ph/isRelatedTo">
        <rdfs:domain rdf:resource="https://sakuna.ph/Incident"/>
        <rdfs:range rdf:resource="https://sakuna.ph/MajorEvent"/>
