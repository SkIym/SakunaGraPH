###  https://sakuna.ph/Wildfire
:Wildfire rdf:type owl:NamedIndividual ,
                   skos:Concept ,
                   :DisasterType ;
          skos:broader :Climatological ;
          skos:inScheme :DisasterTypeScheme ;
          skos:narrower :ForestFire ,
                        :LandFire ,
                        :WildfireGeneral ;
          skos:definition "Any uncontrolled and non-prescribed combustion or burning of plants in a natural setting such as a forest, grassland, brush land or tundra, which consumes natural fuels and spreads based on environmental conditions (e.g., wind, or topography). Wildfires can be triggered by lightning or human actions." ;
          skos:prefLabel "Wildfire"@en .


