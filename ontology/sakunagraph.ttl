@prefix : <https://sakuna.ph/> .
@prefix baw: <https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <https://sakuna.ph/> .

<https://sakuna.ph/> rdf:type owl:Ontology ;
                      owl:imports <http://www.opengis.net/ont/geosparql/1.1> ,
                                  <http://www.w3.org/ns/prov-o-20130430> ,
                                  <https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology> ;
                      rdfs:label "SakunaGraPH" .

#################################################################
#    Datatypes
#################################################################

###  https://sakuna.ph/casualtyDataType
:casualtyDataType rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterLocation
baw:hasDisasterLocation rdf:type owl:ObjectProperty ;
                        owl:inverseOf baw:isLocationOfDisaster ;
                        rdfs:domain :DisasterEvent ;
                        rdfs:range baw:Location ;
                        rdfs:label "has disaster location" ;
                        skos:definition "Represents the location where a natural disaster takes place." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterOccurrence
baw:hasDisasterOccurrence rdf:type owl:ObjectProperty ;
                          owl:inverseOf baw:isOfDisasterType ,
                                        :hasDisasterType ;
                          rdfs:domain :DisasterType ;
                          rdfs:range :DisasterEvent ;
                          rdfs:label "has disaster occurrence" ;
                          skos:definition "Links a natural disaster type to a natural disaster." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasIncidentLocation
baw:hasIncidentLocation rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf baw:hasDisasterLocation ;
                        owl:inverseOf baw:isLocationOfIncident ;
                        rdfs:domain baw:Incident ;
                        rdfs:range baw:Location ;
                        rdfs:label "has incident location" ;
                        skos:definition "Represents the location where an incident occurs." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasIncidentOccurrence
baw:hasIncidentOccurrence rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf baw:hasDisasterOccurrence ;
                          rdfs:domain :DisasterType ;
                          rdfs:range baw:Incident ;
                          rdfs:label "has incident occurrence" ;
                          skos:definition "Links an incident type to an incident." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#isLocationOfDisaster
baw:isLocationOfDisaster rdf:type owl:ObjectProperty ;
                         rdfs:domain baw:Location ;
                         rdfs:range :DisasterEvent ;
                         rdfs:label "is location of disaster" ;
                         skos:definition "Links a location to a natural disaster occurrence." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#isLocationOfIncident
baw:isLocationOfIncident rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf baw:isLocationOfDisaster ;
                         rdfs:domain baw:Location ;
                         rdfs:range baw:Incident ;
                         rdfs:label "is location of incident" ;
                         skos:definition "Links a location to an incident occurrence." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#isOfDisasterType
baw:isOfDisasterType rdf:type owl:ObjectProperty ;
                     owl:equivalentProperty :hasDisasterType ;
                     rdfs:label "is of disaster type" .


###  https://sakuna.ph/fromSource
:fromSource rdf:type owl:ObjectProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( :DisasterEvent
                                        :Impact
                                        :Preparedness
                                        :Response
                                      )
                        ] ;
            rdfs:range :Source ;
            rdfs:label "from source"@en .


###  https://sakuna.ph/hasAffectedPopulation
:hasAffectedPopulation rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :hasImpact ;
                       rdfs:label "has affected population" .


###  https://sakuna.ph/hasAgricultureDamage
:hasAgricultureDamage rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasImpact ;
                      rdfs:label "has agriculture damage" .


###  https://sakuna.ph/hasAirportDisruption
:hasAirportDisruption rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasImpact ;
                      rdfs:label "has airport disruption" .


###  https://sakuna.ph/hasAssistance
:hasAssistance rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :hasResponse ;
               rdfs:label "has assistance" .


###  https://sakuna.ph/hasCasualties
:hasCasualties rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :hasImpact ;
               rdfs:label "has casualties" .


###  https://sakuna.ph/hasClassDisruption
:hasClassDisruption rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasImpact ;
                    rdfs:label "has class disruption" .


###  https://sakuna.ph/hasCommunicationLineDisruption
:hasCommunicationLineDisruption rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf :hasImpact ;
                                rdfs:label "has communication line disruption" .


###  https://sakuna.ph/hasDamageGeneral
:hasDamageGeneral rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasImpact ;
                  rdfs:label "has damage (general)" .


###  https://sakuna.ph/hasDeclarationOfCalamity
:hasDeclarationOfCalamity rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :hasResponse ;
                          rdfs:label "has declaration of calamity" .


###  https://sakuna.ph/hasDisasterSubtype
:hasDisasterSubtype rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasDisasterType ;
                    rdfs:label "has disaster subtype" .


###  https://sakuna.ph/hasDisasterType
:hasDisasterType rdf:type owl:ObjectProperty ;
                 rdfs:domain :DisasterEvent ;
                 rdfs:range :DisasterType ;
                 rdfs:label "has disaster type"@en .


###  https://sakuna.ph/hasHousingDamage
:hasHousingDamage rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasImpact ;
                  rdfs:label "has housing damage" .


###  https://sakuna.ph/hasImpact
:hasImpact rdf:type owl:ObjectProperty ;
           rdfs:domain :DisasterEvent ;
           rdfs:range :Impact ;
           rdfs:label "has disaster impact"@en .


###  https://sakuna.ph/hasInfrastructureDamage
:hasInfrastructureDamage rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :hasImpact ;
                         rdfs:label "has infrastructure damage" .


###  https://sakuna.ph/hasLocation
:hasLocation rdf:type owl:ObjectProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :DisasterEvent
                                         :Impact
                                         :Preparedness
                                         :Response
                                       )
                         ] ;
             rdfs:range :Location ;
             rdfs:label "has location"@en .


###  https://sakuna.ph/hasMunicipality
:hasMunicipality rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasLocation ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :DisasterEvent
                                             :Impact
                                             :Preparedness
                                             :Response
                                           )
                             ] ;
                 rdfs:range :Municipality ;
                 rdfs:comment "Synonymous with City" ;
                 rdfs:label "has municipality or city"@en .


###  https://sakuna.ph/hasPowerDisruption
:hasPowerDisruption rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasImpact ;
                    rdfs:label "has power disruption" .


###  https://sakuna.ph/hasPreemptiveEvacuation
:hasPreemptiveEvacuation rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :hasPreparedness ;
                         rdfs:label "has preemptive evacuation" .


###  https://sakuna.ph/hasPreparedness
:hasPreparedness rdf:type owl:ObjectProperty ;
                 rdfs:domain :DisasterEvent ;
                 rdfs:range :Preparedness ;
                 rdfs:label "has preparedness" .


###  https://sakuna.ph/hasProvince
:hasProvince rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasLocation ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :DisasterEvent
                                         :Impact
                                         :Preparedness
                                         :Response
                                       )
                         ] ;
             rdfs:range :Province ;
             rdfs:label "has province"@en .


###  https://sakuna.ph/hasRecovery
:hasRecovery rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasResponse ;
             rdfs:label "has recovery" .


###  https://sakuna.ph/hasRegion
:hasRegion rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasLocation ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :DisasterEvent
                                       :Impact
                                       :Preparedness
                                       :Response
                                     )
                       ] ;
           rdfs:range :Region ;
           rdfs:label "has region"@en .


###  https://sakuna.ph/hasRelatedIncident
:hasRelatedIncident rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isRelatedTo ;
                    rdfs:domain :MajorEvent ;
                    rdfs:range :Incident ;
                    rdfs:label "has related incident"@en .


###  https://sakuna.ph/hasRelief
:hasRelief rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasResponse ;
           rdfs:label "has relief" .


###  https://sakuna.ph/hasRescue
:hasRescue rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasPreparedness ;
           rdfs:label "has rescue" .


###  https://sakuna.ph/hasResponse
:hasResponse rdf:type owl:ObjectProperty ;
             rdfs:domain :DisasterEvent ;
             rdfs:range :Response ;
             rdfs:label "has response"@en .


###  https://sakuna.ph/hasRoadAndBridgesDamage
:hasRoadAndBridgesDamage rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :hasImpact ;
                         rdfs:label "has road and bridges damage" .


###  https://sakuna.ph/hasSeaportDisruption
:hasSeaportDisruption rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasImpact ;
                      rdfs:label "has seaport disruption" .


###  https://sakuna.ph/hasStrandedEvent
:hasStrandedEvent rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasImpact ;
                  rdfs:label "has stranded event" .


###  https://sakuna.ph/hasWaterDisruption
:hasWaterDisruption rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasImpact ;
                    rdfs:label "has water disruption" .


###  https://sakuna.ph/hasWorkDisruption
:hasWorkDisruption rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :hasImpact ;
                   rdfs:label "has work disruption" .


###  https://sakuna.ph/isPartOf
:isPartOf rdf:type owl:ObjectProperty ,
                   owl:TransitiveProperty ;
          rdfs:domain [ rdf:type owl:Class ;
                        owl:unionOf ( :Barangay
                                      :IslandGroup
                                      :Municipality
                                      :Province
                                      :Region
                                    )
                      ] ;
          rdfs:range [ rdf:type owl:Class ;
                       owl:unionOf ( :Country
                                     :IslandGroup
                                     :Municipality
                                     :Province
                                     :Region
                                   )
                     ] ;
          rdfs:label "is part of"@en .


###  https://sakuna.ph/isRelatedTo
:isRelatedTo rdf:type owl:ObjectProperty ;
             rdfs:domain :Incident ;
             rdfs:range :MajorEvent ;
             rdfs:label "is related to"@en .


#################################################################
#    Data properties
#################################################################

###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterEnd
baw:hasDisasterEnd rdf:type owl:DatatypeProperty ;
                   owl:equivalentProperty :endDate ;
                   rdfs:domain :DisasterEvent ;
                   rdfs:range xsd:dateTime ;
                   rdfs:label "has disaster end" ;
                   skos:definition "Indicates the end of the disaster." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#hasDisasterStart
baw:hasDisasterStart rdf:type owl:DatatypeProperty ;
                     owl:equivalentProperty :startDate ;
                     rdfs:domain :DisasterEvent ;
                     rdfs:range xsd:dateTime ;
                     rdfs:label "has disaster start" ;
                     skos:definition "Indicates the start of the disaster." .


###  https://sakuna.ph/affectedBarangays
:affectedBarangays rdf:type owl:DatatypeProperty ;
                   rdfs:domain :AffectedPopulation ;
                   rdfs:range xsd:int ;
                   rdfs:label "affected barangays"@en .


###  https://sakuna.ph/affectedDescription
:affectedDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( :AirportDisruption
                                                 :ClassSuspension
                                                 :CommunicationLineDisruption
                                                 :PowerDisruption
                                                 :RoadAndBridgesDamage
                                                 :SeaportDisruption
                                                 :WaterDisruption
                                                 :WorkSuspension
                                               )
                                 ] ;
                     rdfs:range xsd:string ;
                     rdfs:label "affected description" ;
                     skos:definition "General (unprocessed) information about the affected entity." .


###  https://sakuna.ph/affectedFamilies
:affectedFamilies rdf:type owl:DatatypeProperty ;
                  rdfs:domain :AffectedPopulation ;
                  rdfs:range xsd:int ;
                  rdfs:label "affected families"@en .


###  https://sakuna.ph/affectedPersons
:affectedPersons rdf:type owl:DatatypeProperty ;
                 rdfs:domain :AffectedPopulation ;
                 rdfs:range xsd:int ;
                 rdfs:label "affected persons"@en .


###  https://sakuna.ph/agencyLGUsPresent
:agencyLGUsPresent rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :Assistance
                                               :Preparedness
                                             )
                               ] ;
                   rdfs:range xsd:string ;
                   rdfs:label "agency and LGUs present"@en .


###  https://sakuna.ph/agriDamageAmount
:agriDamageAmount rdf:type owl:DatatypeProperty ;
                  rdfs:domain :AgricultureDamage ;
                  rdfs:range xsd:decimal ;
                  rdfs:comment "From Department of Geography digitized archives" ,
                               "In M PHP" ;
                  rdfs:label "agriculture damage amount"@en .


###  https://sakuna.ph/agriDamageClassification
:agriDamageClassification rdf:type owl:DatatypeProperty ;
                          rdfs:domain :AgricultureDamage ;
                          rdfs:range xsd:string ;
                          rdfs:label "agriculture damage classification"@en .


###  https://sakuna.ph/agriDamageQuantity
:agriDamageQuantity rdf:type owl:DatatypeProperty ;
                    rdfs:domain :AgricultureDamage ;
                    rdfs:range xsd:decimal ;
                    rdfs:label "agriculture damage quantity" .


###  https://sakuna.ph/agriDamageType
:agriDamageType rdf:type owl:DatatypeProperty ;
                rdfs:domain :AgricultureDamage ;
                rdfs:range xsd:string ;
                rdfs:label "agriculture damage type"@en .


###  https://sakuna.ph/agriDamageUnit
:agriDamageUnit rdf:type owl:DatatypeProperty ;
                rdfs:domain :AgricultureDamage ;
                rdfs:range xsd:string ;
                rdfs:label "agriculture damage unit" .


###  https://sakuna.ph/airline
:airline rdf:type owl:DatatypeProperty ;
         rdfs:domain :FlightDisruption ;
         rdfs:range xsd:string ;
         rdfs:label "airline"@en .


###  https://sakuna.ph/airportType
:airportType rdf:type owl:DatatypeProperty ;
             rdfs:domain :FlightDisruption ;
             rdfs:range xsd:string ;
             rdfs:label "airport type"@en .


###  https://sakuna.ph/allocatedFunds
:allocatedFunds rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Assistance ;
                rdfs:range xsd:decimal ;
                rdfs:label "allocated funds"@en ;
                skos:note "In M Php" .


###  https://sakuna.ph/amountDSWD
:amountDSWD rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Assistance ;
            rdfs:range xsd:decimal ;
            rdfs:label "amount from DWSD"@en .


###  https://sakuna.ph/amountLGU
:amountLGU rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :Assistance ;
           rdfs:range xsd:decimal ;
           rdfs:label "amount from LGU"@en .


###  https://sakuna.ph/amountNGOs
:amountNGOs rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Assistance ;
            rdfs:range xsd:decimal ;
            rdfs:label "amount from NGOs and/or international orgs"@en .


###  https://sakuna.ph/amountOCD
:amountOCD rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :Assistance ;
           rdfs:range xsd:decimal ;
           rdfs:label "amount from OCD"@en .


###  https://sakuna.ph/amountOtherGOs
:amountOtherGOs rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Assistance ;
                rdfs:range xsd:decimal ;
                rdfs:label "amount from other GOs"@en .


###  https://sakuna.ph/announcementsReleased
:announcementsReleased rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Preparedness ;
                       rdfs:range xsd:string ;
                       rdfs:label "announcements released" ;
                       skos:definition "Announcements released during preparation for a disaster." .


###  https://sakuna.ph/cancellationDateTime
:cancellationDateTime rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( :AirportDisruption
                                                  :ClassSuspension
                                                  :FlightDisruption
                                                  :SeaportDisruption
                                                  :WorkSuspension
                                                )
                                  ] ;
                      rdfs:range xsd:dateTime ;
                      rdfs:label "cancellation datetime"@en ;
                      skos:altLabel "non-operational datetime" ,
                                    "suspension datetime" .


###  https://sakuna.ph/casualtyCause
:casualtyCause rdf:type owl:DatatypeProperty ;
               rdfs:domain :Casualties ;
               rdfs:range xsd:string ;
               rdfs:label "cause of casualty"@en .


###  https://sakuna.ph/casualtyCount
:casualtyCount rdf:type owl:DatatypeProperty ;
               rdfs:domain :Casualties ;
               rdfs:range xsd:int ;
               rdfs:label "count of casualty" .


###  https://sakuna.ph/casualtyDataSource
:casualtyDataSource rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Casualties ;
                    rdfs:range xsd:string ;
                    rdfs:label "source of casualty data" .


###  https://sakuna.ph/casualtyType
:casualtyType rdf:type owl:DatatypeProperty ;
              rdfs:domain :Casualties ;
              rdfs:range :casualtyDataType ;
              rdfs:label "type of casualty" .


###  https://sakuna.ph/cityClass
:cityClass rdf:type owl:DatatypeProperty ;
           rdfs:domain :Location ;
           rdfs:range xsd:string ;
           rdfs:label "city class" .


###  https://sakuna.ph/commercialDamageAmount
:commercialDamageAmount rdf:type owl:DatatypeProperty ;
                        rdfs:domain :InfrastructureDamage ;
                        rdfs:range xsd:decimal ;
                        rdfs:comment "In M PHP" ;
                        rdfs:label "commercial damage amount"@en ;
                        skos:altLabel "private damage amount" .


###  https://sakuna.ph/communicationStatus
:communicationStatus rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :CommunicationLineDisruption ;
                     rdfs:range xsd:string ;
                     rdfs:label "communication status"@en .


###  https://sakuna.ph/contributionAID
:contributionAID rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Assistance ;
                 rdfs:range xsd:decimal ;
                 rdfs:label "AID contribution"@en .


###  https://sakuna.ph/correspondenceCode
:correspondenceCode rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Location ;
                    rdfs:range xsd:string ;
                    rdfs:label "correspondence code" .


###  https://sakuna.ph/cpi
:cpi rdf:type owl:DatatypeProperty ;
     rdfs:domain :DamageGeneral ;
     rdfs:range xsd:decimal ;
     rdfs:label "cpi"@en .


###  https://sakuna.ph/crossSectoralDamageAmount
:crossSectoralDamageAmount rdf:type owl:DatatypeProperty ;
                           rdfs:domain :InfrastructureDamage ;
                           rdfs:range xsd:decimal ;
                           rdfs:comment "In M PHP" ;
                           rdfs:label "cross sectoral damage amount" ;
                           skos:example "health government, transmission lines" .


###  https://sakuna.ph/declarationType
:declarationType rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :DeclarationOfCalamity ;
                 rdfs:range xsd:string ;
                 rdfs:label "declaration of state of calamity type"@en .


###  https://sakuna.ph/displacedFamilies
:displacedFamilies rdf:type owl:DatatypeProperty ;
                   rdfs:domain :AffectedPopulation ;
                   rdfs:range xsd:int ;
                   rdfs:comment "Synonymous with served or evacuated families (in or out of centers) and refers to the cumulative count." ;
                   rdfs:label "displaced families"@en .


###  https://sakuna.ph/displacedPersons
:displacedPersons rdf:type owl:DatatypeProperty ;
                  rdfs:domain :AffectedPopulation ;
                  rdfs:range xsd:int ;
                  rdfs:comment "Synonymous with served or evacuated persons (in or out of centers) and refers to the cumulative count." ;
                  rdfs:label "displaced persons"@en .


###  https://sakuna.ph/disruptionType
:disruptionType rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :PowerDisruption
                                            :WaterDisruption
                                          )
                            ] ;
                rdfs:range xsd:string ;
                rdfs:label "disruption type"@en .


###  https://sakuna.ph/district
:district rdf:type owl:DatatypeProperty ;
          rdfs:domain :StrandedEvent ;
          rdfs:range xsd:string ;
          rdfs:label "district"@en .


###  https://sakuna.ph/endDate
:endDate rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain :DisasterEvent ;
         rdfs:range xsd:dateTime ;
         rdfs:label "end date"@en .


###  https://sakuna.ph/entryDate
:entryDate rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :DisasterEvent ;
           rdfs:range xsd:dateTime ;
           rdfs:label "data entry date"@en .


###  https://sakuna.ph/evacuationCenters
:evacuationCenters rdf:type owl:DatatypeProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :AffectedPopulation
                                               :PreemptiveEvacuation
                                             )
                               ] ;
                   rdfs:range xsd:int ;
                   rdfs:label "no. of evacuation centers"@en .


###  https://sakuna.ph/evacuationPlan
:evacuationPlan rdf:type owl:DatatypeProperty ;
                rdfs:domain :PreemptiveEvacuation ;
                rdfs:range xsd:string ;
                rdfs:label "evacuation plan" .


###  https://sakuna.ph/eventName
:eventName rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :DisasterEvent ;
           rdfs:range xsd:string ;
           rdfs:label "event name"@en .


###  https://sakuna.ph/farmerFisherfolkAffected
:farmerFisherfolkAffected rdf:type owl:DatatypeProperty ;
                          rdfs:domain :AgricultureDamage ;
                          rdfs:range xsd:int ;
                          rdfs:label "no. of farmer and fisherfolks affected"@en .


###  https://sakuna.ph/flightNo
:flightNo rdf:type owl:DatatypeProperty ;
          rdfs:domain :FlightDisruption ;
          rdfs:range xsd:string ;
          rdfs:label "flight no."@en .


###  https://sakuna.ph/flightRoute
:flightRoute rdf:type owl:DatatypeProperty ;
