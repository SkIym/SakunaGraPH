###  http://www.opengis.net/ont/geosparql#Feature
geo:Feature rdf:type owl:Class .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Impact
baw:Impact rdf:type owl:Class ;
           owl:equivalentClass :Impact ;
           rdfs:label "Impact" ;
           skos:definition "Represents the impact of natural disasters and incidents." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Incident
baw:Incident rdf:type owl:Class ;
             owl:equivalentClass :Incident ;
             rdfs:label "Incident" ;
             skos:definition "Represents the various incidents taking place during a natural disaster." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Location
baw:Location rdf:type owl:Class ;
             owl:equivalentClass :Location .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#NaturalDisaster
baw:NaturalDisaster rdf:type owl:Class ;
                    rdfs:subClassOf :DisasterEvent ;
                    rdfs:label "Natural Disaster" ;
                    skos:definition "Represents the actual manifestation of a natural disaster type. An instance of a natural disaster has specific climate conditions with specific values (e.g. temperature = 45) plus some other properties (e.g. start/end time)." .


###  https://sakuna.ph/AffectedPopulation
:AffectedPopulation rdf:type owl:Class ;
                    rdfs:subClassOf :Impact ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :affectedBarangays ;
                                      owl:someValuesFrom xsd:integer
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :affectedFamilies ;
                                      owl:someValuesFrom xsd:int
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :affectedPersons ;
                                      owl:someValuesFrom xsd:int
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :displacedFamilies ;
                                      owl:someValuesFrom xsd:int
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :displacedPersons ;
                                      owl:someValuesFrom xsd:int
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :evacuationCenters ;
                                      owl:someValuesFrom xsd:int
                                    ] ;
                    rdfs:label "Affected Population"@en ;
                    skos:definition "Represents affected and displaced persons or families." .


###  https://sakuna.ph/AgricultureDamage
:AgricultureDamage rdf:type owl:Class ;
                   rdfs:subClassOf :Impact ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageAmount ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageClassification ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageQuantity ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageType ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageUnit ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :farmerFisherfolkAffected ;
                                     owl:someValuesFrom xsd:integer
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :partiallyDamagedCropArea ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :partiallyDamagedInfrastructure ;
                                     owl:someValuesFrom xsd:integer
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :productionLossCost ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :productionLossVolume ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :totallyDamagedCropArea ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :totallyDamagedInfrastructure ;
                                     owl:someValuesFrom xsd:integer
                                   ] ;
                   rdfs:label "Agriculture Damage"@en ;
                   skos:definition "Represents damage on agriculture, farmers, fisherfolks, and crops." .


###  https://sakuna.ph/AirportDisruption
:AirportDisruption rdf:type owl:Class ;
                   rdfs:subClassOf :Impact ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :cancellationDateTime ;
                                     owl:someValuesFrom xsd:dateTime
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :portOrTerminalName ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :portStatus ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :resumptionDateTime ;
                                     owl:someValuesFrom xsd:dateTime
                                   ] ;
                   rdfs:label "Airport Disruption" ;
                   skos:altLabel "Flight Disruption" ;
                   skos:definition "Represents disruptions on airports." .


###  https://sakuna.ph/Assistance
:Assistance rdf:type owl:Class ;
            rdfs:subClassOf :Response ;
            rdfs:label "Assistance"@en ;
            skos:definition "Represents the monetary assistance provided during or after a disaster event." .


###  https://sakuna.ph/Barangay
:Barangay rdf:type owl:Class ;
          rdfs:subClassOf :Location ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isPartOf ;
                            owl:someValuesFrom :Municipality
                          ] ;
          rdfs:label "Barangay"@en ;
          skos:definition "adm level 4" .


###  https://sakuna.ph/Casualties
:Casualties rdf:type owl:Class ;
            rdfs:subClassOf :Impact ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :casualtyCause ;
                              owl:someValuesFrom xsd:string
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :casualtyCount ;
                              owl:someValuesFrom xsd:int
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :casualtyDataSource ;
                              owl:someValuesFrom xsd:string
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :casualtyType ;
                              owl:someValuesFrom :casualtyDatatype
                            ] ;
            rdfs:label "Casualties"@en ;
            skos:definition "Represents the number of deaths, injured, and missing due to a disaster." .


###  https://sakuna.ph/City
:City rdf:type owl:Class ;
      rdfs:subClassOf :Location ;
      rdfs:label "City" ;
      skos:definition "adm level 3" .


###  https://sakuna.ph/ClassSuspension
:ClassSuspension rdf:type owl:Class ;
                 rdfs:subClassOf :Impact ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :cancellationDateTime ;
                                   owl:someValuesFrom xsd:dateTime
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :fromClassLevel ;
                                   owl:someValuesFrom xsd:string
