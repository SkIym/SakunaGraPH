                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :preemptMales ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :preemptPersons ;
                                        owl:someValuesFrom xsd:int
                                      ] ;
                      rdfs:label "Preemptive Evacuation"@en ;
                      skos:definition "Represents information on evacuation centers and preemptively evacuated individuals." .


###  https://sakuna.ph/Preparedness
:Preparedness rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Restriction ;
                                    owl:onProperty :agencyLGUsPresent ;
                                    owl:someValuesFrom xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :announcementsReleased ;
                                    owl:someValuesFrom xsd:string
                                  ] ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :fromSource ;
                                owl:someValuesFrom :Source
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasLocation ;
                                owl:someValuesFrom :Location
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasMunicipality ;
                                owl:someValuesFrom :Municipality
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasProvince ;
                                owl:someValuesFrom :Province
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasRegion ;
                                owl:someValuesFrom :Region
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasBarangay ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :remarks ;
                                owl:someValuesFrom xsd:string
                              ] ;
              rdfs:label "Preparedness" ;
              skos:definition "Represents preparations done by government or non-government units before a disaster event." .


###  https://sakuna.ph/PrionDisease
:PrionDisease rdf:type owl:Class ;
              rdfs:subClassOf :Epidemic ;
              rdfs:label "Prion Disease"@en ;
              skos:definition "Prion disease: A type of biological hazard caused by prion proteins. Prion diseases or transmissible spongiform encephalopathies (TSEs) are a family of rare progressive neurodegenerative disorders that affect both humans and animals. They are characterized by long incubation periods and neural loss. Examples are Bovine Spongiform Encephalopathy (BSE), Creutzfeldt-Jakob Disease (CJD), Kuru, etc." .


###  https://sakuna.ph/Province
:Province rdf:type owl:Class ;
          rdfs:subClassOf :Location ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isPartOf ;
                            owl:someValuesFrom :Region
                          ] ;
          rdfs:label "Province"@en ;
          skos:definition "adm level 2" .


###  https://sakuna.ph/PyroclasticFlow
:PyroclasticFlow rdf:type owl:Class ;
                 rdfs:subClassOf :VolcanicActivity ;
                 rdfs:label "Pyroclastic Flow"@en ;
                 skos:definition "Pyroclastic Flow: Extremely hot gases, ash, and other materials with a temperature of more than 1,000 degrees Celsius that rapidly flow down the flank of a volcano (at more than 700 km/h) during an eruption." .


###  https://sakuna.ph/Radiation
:Radiation rdf:type owl:Class ;
           rdfs:subClassOf :IndustrialAccident ;
           rdfs:label "Radiation"@en ;
           skos:definition "Radiation: Exposure to harmful radiation or reactive substances." .


###  https://sakuna.ph/Rail
:Rail rdf:type owl:Class ;
      rdfs:subClassOf :Transport ;
      rdfs:label "Rail"@en ;
      skos:definition "Rail: Transport accidents involving trains." .


