:PowerDisruption rdf:type owl:Class ;
                 rdfs:subClassOf :Impact ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :affectedDescription ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :disruptionType ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
