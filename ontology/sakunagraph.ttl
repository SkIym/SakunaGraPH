                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :suspensionType ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :toClassLevel ;
                                   owl:someValuesFrom xsd:string
                                 ] ;
                 rdfs:label "Class Suspension"@en ;
                 skos:definition "Represents education operational disruptions." .


###  https://sakuna.ph/CommunicationLineDisruption
:CommunicationLineDisruption rdf:type owl:Class ;
                             rdfs:subClassOf :Impact ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :communicationStatus ;
                                               owl:someValuesFrom xsd:string
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :interruptionDateTime ;
                                               owl:someValuesFrom xsd:dateTime
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :restorationDateTime ;
                                               owl:someValuesFrom xsd:dateTime
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :telecompany ;
                                               owl:someValuesFrom xsd:string
                                             ] ;
                             rdfs:label "Communication Line Disruption"@en ;
                             skos:definition "Represents impact on communication lines." .


###  https://sakuna.ph/Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf :Location ;
         rdfs:label "Country" ;
         skos:definition "adm level 0" .


###  https://sakuna.ph/DamageGeneral
:DamageGeneral rdf:type owl:Class ;
               rdfs:subClassOf :Impact ;
               rdfs:label "Damage (General)"@en ;
               skos:definition "Represents general damage that does not fall under any sibling classes." .


###  https://sakuna.ph/DeclarationOfCalamity
:DeclarationOfCalamity rdf:type owl:Class ;
                       rdfs:subClassOf :Response ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :declarationType ;
                                         owl:someValuesFrom xsd:string
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :resolutionDate ;
                                         owl:someValuesFrom xsd:dateTime
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :resolutionNo ;
                                         owl:someValuesFrom xsd:string
                                       ] ;
                       rdfs:label "Declaration of Calamity"@en ;
                       skos:definition "Represents events of state of calamity declaration." .


###  https://sakuna.ph/DisasterEvent
:DisasterEvent rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasImpact ;
                                 owl:someValuesFrom :Impact
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasLocation ;
                                 owl:someValuesFrom :Location
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasMunicipality ;
                                 owl:someValuesFrom :Municipality
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasProvince ;
                                 owl:someValuesFrom :Province
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasRegion ;
                                 owl:someValuesFrom :Region
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasResponse ;
                                 owl:someValuesFrom :Response
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :endDate ;
                                 owl:someValuesFrom xsd:dateTime
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :entryDate ;
                                 owl:someValuesFrom xsd:dateTime
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :eventName ;
                                 owl:someValuesFrom xsd:string
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasBarangay ;
                                 owl:someValuesFrom xsd:string
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :reference ;
                                 owl:someValuesFrom xsd:string
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :remarks ;
                                 owl:someValuesFrom xsd:string
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :startDate ;
                                 owl:someValuesFrom xsd:dateTime
                               ] ;
               rdfs:label "Disaster Event"@en ;
               skos:definition "Any event that has dealt notable impact to the population, infrastructure, or has disrupted operations and services." .


###  https://sakuna.ph/DisasterType
:DisasterType rdf:type owl:Class ;
              rdfs:label "Disaster Type" ;
              skos:definition "Disaster type based on the Emergency Events Database (EM-DAT) classification of disasters." .


###  https://sakuna.ph/DisasterTypeScheme
:DisasterTypeScheme rdf:type owl:Class .


###  https://sakuna.ph/FlightDisruption
:FlightDisruption rdf:type owl:Class ;
                  rdfs:subClassOf :Impact ;
                  rdfs:label "Flight Disruption" .


###  https://sakuna.ph/HousingDamage
:HousingDamage rdf:type owl:Class ;
               rdfs:subClassOf :Impact ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :housingDamageAmount ;
                                 owl:someValuesFrom xsd:decimal
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :partiallyDamagedHouses ;
                                 owl:someValuesFrom xsd:int
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :totallyDamagedHouses ;
                                 owl:someValuesFrom xsd:int
                               ] ;
               rdfs:label "Housing Damage"@en ;
               skos:definition "Represents impact on housing." .


###  https://sakuna.ph/Impact
:Impact rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasLocation ;
                          owl:someValuesFrom :Location
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasMunicipality ;
                          owl:someValuesFrom :Municipality
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasProvince ;
                          owl:someValuesFrom :Province
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRegion ;
                          owl:someValuesFrom :Region
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasBarangay ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :remarks ;
                          owl:someValuesFrom xsd:string
                        ] ;
        owl:disjointWith [ owl:intersectionOf ( :DisasterEvent
                                                :Location
                                                :Preparedness
                                                :Response
                                              ) ;
                           rdf:type owl:Class
                         ] ;
        rdfs:label "Impact"@en ;
        skos:definition "Represents the impact of major or incident disasters." .


###  https://sakuna.ph/Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :DisasterEvent ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :incidentActionsTaken ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :incidentDescription ;
                            owl:someValuesFrom xsd:string
                          ] ;
          owl:disjointWith :MajorEvent ;
          rdfs:label "Incident"@en ;
          skos:definition "A localized or small-scale disaster event, often reported at the municipal or barangay level and is related with a bigger, major event." .


###  https://sakuna.ph/InfrastructureDamage
:InfrastructureDamage rdf:type owl:Class ;
                      rdfs:subClassOf :Impact ,
                                      [ rdf:type owl:Restriction ;
