###  http://qudt.org/schema/qudt/CurrencyUnit
qudt:CurrencyUnit rdf:type owl:Class ;
                  rdfs:label "Currency Unit"@en .


###  http://qudt.org/schema/qudt/QuantityValue
qudt:QuantityValue rdf:type owl:Class ;
                   rdfs:label "Quantity Value"@en .


###  http://www.opengis.net/ont/geosparql#Feature
geo:Feature rdf:type owl:Class ;
            rdfs:label "Feature"@en ;
            skos:definition "A discrete spatial phenomenon in a universe of discourse."@en .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#ClimateParameter
baw:ClimateParameter rdf:type owl:Class ;
                     rdfs:label "Climate Parameter" ;
                     skos:definition "Represents the actual manifestation of a climate parameter measurement." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#ClimateParameterType
baw:ClimateParameterType rdf:type owl:Class ;
                         rdfs:label "Climate Parameter Type" ;
                         skos:definition "Represents various types of climate-related parameters." ;
                         skos:example "Temperature, humidity, etc." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Impact
baw:Impact rdf:type owl:Class ;
           owl:equivalentClass :Impact ;
           rdfs:label "Impact" ;
           skos:definition "Represents the impact of natural disasters and incidents." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Incident
baw:Incident rdf:type owl:Class ;
             owl:equivalentClass :Incident ;
             rdfs:label "Incident" ;
             skos:definition "Represents the various incidents taking place during a natural disaster." .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#Location
baw:Location rdf:type owl:Class ;
             owl:equivalentClass :Location .


###  https://raw.githubusercontent.com/beAWARE-project/ontology/master/beAWARE_ontology#NaturalDisaster
baw:NaturalDisaster rdf:type owl:Class ;
                    rdfs:subClassOf :DisasterEvent ;
                    rdfs:label "Natural Disaster" ;
                    skos:definition "Represents the actual manifestation of a natural disaster type. An instance of a natural disaster has specific climate conditions with specific values (e.g. temperature = 45) plus some other properties (e.g. start/end time)." .


###  https://sakuna.ph/AffectedPopulation
:AffectedPopulation rdf:type owl:Class ;
                    rdfs:subClassOf :Impact ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :affectedBarangays ;
                                      owl:someValuesFrom xsd:integer
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :affectedFamilies ;
                                      owl:someValuesFrom xsd:int
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :affectedPersons ;
                                      owl:someValuesFrom xsd:int
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :displacedFamilies ;
                                      owl:someValuesFrom xsd:int
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :displacedPersons ;
                                      owl:someValuesFrom xsd:int
                                    ] ;
                    rdfs:label "Affected Population"@en ;
                    skos:definition "Represents affected and displaced persons or families." .


###  https://sakuna.ph/AgricultureDamage
:AgricultureDamage rdf:type owl:Class ;
                   rdfs:subClassOf :Impact ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageAmount ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageClassification ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageQuantity ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageType ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :agriDamageUnit ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :farmerFisherfolkAffected ;
                                     owl:someValuesFrom xsd:integer
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :partiallyDamagedCropArea ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :partiallyDamagedInfrastructure ;
                                     owl:someValuesFrom xsd:integer
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :productionLossCost ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :productionLossVolume ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :totallyDamagedCropArea ;
                                     owl:someValuesFrom xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :totallyDamagedInfrastructure ;
                                     owl:someValuesFrom xsd:integer
                                   ] ;
                   rdfs:label "Agriculture Damage"@en ;
                   skos:definition "Represents damage on agriculture, farmers, fisherfolks, and crops." .


###  https://sakuna.ph/AirportDisruption
:AirportDisruption rdf:type owl:Class ;
                   rdfs:subClassOf :Impact ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :affectedDescription ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :cancellationDateTime ;
                                     owl:someValuesFrom xsd:dateTime
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :portOrTerminalName ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :portStatus ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :resumptionDateTime ;
                                     owl:someValuesFrom xsd:dateTime
                                   ] ;
                   owl:disjointWith [ owl:intersectionOf ( :ClassSuspension
                                                           :CommunicationLineDisruption
                                                           :PowerDisruption
                                                           :RoadAndBridgesDamage
                                                           :SeaportDisruption
                                                           :WaterDisruption
                                                           :WorkSuspension
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                   rdfs:label "Airport Disruption" ;
                   skos:altLabel "Flight Disruption" ;
                   skos:definition "Represents disruptions on airports." .


###  https://sakuna.ph/Assistance
:Assistance rdf:type owl:Class ;
            rdfs:subClassOf :Response ;
            rdfs:label "Assistance"@en ;
            skos:altLabel "Relief" ;
            skos:definition "Represents the monetary assistance provided during or after a disaster event." .


###  https://sakuna.ph/Barangay
:Barangay rdf:type owl:Class ;
          rdfs:subClassOf :Location ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isPartOf ;
                            owl:someValuesFrom :Municipality
                          ] ;
          rdfs:label "Barangay"@en ;
          skos:definition "Administrative Level 4" .


###  https://sakuna.ph/Casualties
:Casualties rdf:type owl:Class ;
            rdfs:subClassOf :Impact ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :isOfCasualtyType ;
                              owl:someValuesFrom :CasualtyType
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :casualtyCause ;
                              owl:someValuesFrom xsd:string
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :casualtyCount ;
                              owl:someValuesFrom xsd:int
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :casualtyDataSource ;
                              owl:someValuesFrom xsd:string
                            ] ;
            rdfs:label "Casualties"@en ;
            skos:definition "Represents the number of deaths, injured, and missing due to a disaster." .


###  https://sakuna.ph/CasualtyType
:CasualtyType rdf:type owl:Class ;
              rdfs:label "Casualty Type" ;
              skos:definition "Represents various types of casualties" ;
              skos:example "Dead, injured, missing" .


###  https://sakuna.ph/City
:City rdf:type owl:Class ;
      rdfs:subClassOf :Location ;
      rdfs:label "City" ;
      skos:definition "Administrative Level 3" .


###  https://sakuna.ph/ClassSuspension
:ClassSuspension rdf:type owl:Class ;
                 rdfs:subClassOf :Impact ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :affectedDescription ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :cancellationDateTime ;
                                   owl:someValuesFrom xsd:dateTime
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :fromClassLevel ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :resumptionDateTime ;
                                   owl:someValuesFrom xsd:dateTime
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :suspensionType ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :toClassLevel ;
                                   owl:someValuesFrom xsd:string
                                 ] ;
                 rdfs:label "Class Suspension"@en ;
                 skos:definition "Represents education operational disruptions." .


###  https://sakuna.ph/CommunicationLineDisruption
:CommunicationLineDisruption rdf:type owl:Class ;
                             rdfs:subClassOf :Impact ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :affectedDescription ;
                                               owl:someValuesFrom xsd:string
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :communicationStatus ;
                                               owl:someValuesFrom xsd:string
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :interruptionDateTime ;
                                               owl:someValuesFrom xsd:dateTime
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :restorationDateTime ;
                                               owl:someValuesFrom xsd:dateTime
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :telecompany ;
                                               owl:someValuesFrom xsd:string
                                             ] ;
                             rdfs:label "Communication Line Disruption"@en ;
                             skos:definition "Represents impact on communication lines." .


###  https://sakuna.ph/Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf :Location ;
         rdfs:label "Country" ;
         skos:definition "Administrative Level 0" .


###  https://sakuna.ph/DamageGeneral
:DamageGeneral rdf:type owl:Class ;
               rdfs:subClassOf :Impact ;
               rdfs:label "Damage (General)"@en ;
               skos:definition "Represents general damage that does not fall under any sibling classes." .


###  https://sakuna.ph/DeclarationOfCalamity
:DeclarationOfCalamity rdf:type owl:Class ;
                       rdfs:subClassOf :Response ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :declarationType ;
                                         owl:someValuesFrom xsd:string
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :resolutionDate ;
                                         owl:someValuesFrom xsd:dateTime
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :resolutionNo ;
                                         owl:someValuesFrom xsd:string
                                       ] ;
                       rdfs:label "Declaration of Calamity"@en ;
                       skos:definition "Represents events of state of calamity declaration." .


###  https://sakuna.ph/DisasterEvent
:DisasterEvent rdf:type owl:Class ;
               rdfs:subClassOf prov:Entity ;
               rdfs:label "Disaster Event"@en ;
               skos:definition "Any event that has dealt notable impact to the population, infrastructure, or has disrupted operations and services." .


###  https://sakuna.ph/DisasterType
:DisasterType rdf:type owl:Class ;
              rdfs:label "Disaster Type" ;
              skos:definition "Disaster type based on the Emergency Events Database (EM-DAT) classification of disasters." .


###  https://sakuna.ph/DisasterTypeScheme
:DisasterTypeScheme rdf:type owl:Class .


###  https://sakuna.ph/FlightDisruption
:FlightDisruption rdf:type owl:Class ;
                  rdfs:subClassOf :Impact ;
                  rdfs:label "Flight Disruption" ;
                  skos:definition "Represents flight disruptions." .


###  https://sakuna.ph/HousingDamage
:HousingDamage rdf:type owl:Class ;
               rdfs:subClassOf :Impact ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :housingDamageAmount ;
                                 owl:someValuesFrom xsd:decimal
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :partiallyDamagedHouses ;
                                 owl:someValuesFrom xsd:int
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :totallyDamagedHouses ;
                                 owl:someValuesFrom xsd:int
                               ] ;
               rdfs:label "Housing Damage"@en ;
               skos:definition "Represents impact on housing." .


###  https://sakuna.ph/Impact
:Impact rdf:type owl:Class ;
        owl:disjointWith [ owl:intersectionOf ( :DisasterEvent
                                                :Location
                                                :Preparedness
                                                :Response
                                              ) ;
                           rdf:type owl:Class
                         ] ;
        rdfs:label "Impact"@en ;
        skos:definition "Represents the impact of major or incident disasters." .


###  https://sakuna.ph/Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :DisasterEvent ;
          owl:disjointWith :MajorEvent ;
          rdfs:label "Incident"@en ;
          skos:definition "A localized or small-scale disaster event, often reported at the municipal or barangay level and is related with a bigger, major event." .


###  https://sakuna.ph/InfrastructureDamage
:InfrastructureDamage rdf:type owl:Class ;
                      rdfs:subClassOf :Impact ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :commercialDamageAmount ;
                                        owl:someValuesFrom xsd:decimal
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :crossSectoralDamageAmount ;
                                        owl:someValuesFrom xsd:decimal
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :infraDamageAmount ;
                                        owl:someValuesFrom xsd:decimal
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :infraDamageClassification ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :infraDamageType ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :infraName ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :infraQtyDamaged ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :infraUnitDamaged ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :numberInfraDamaged ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :socialDamageAmount ;
                                        owl:someValuesFrom xsd:decimal
                                      ] ;
                      rdfs:label "Infrastructure Damage"@en ;
                      skos:definition "Represents impact on infrastructure." .


###  https://sakuna.ph/IslandGroup
:IslandGroup rdf:type owl:Class ;
             rdfs:subClassOf :Location ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :isPartOf ;
                               owl:someValuesFrom :Country
                             ] ;
             rdfs:label "Island Group" ;
             skos:definition "Represents island groups" .


###  https://sakuna.ph/Location
:Location rdf:type owl:Class ;
          rdfs:subClassOf geo:Feature ;
          rdfs:label "Location"@en ;
          skos:definition "Represents tiered locations (administrative levels) in the Philippines." .


###  https://sakuna.ph/MajorEvent
:MajorEvent rdf:type owl:Class ;
            rdfs:subClassOf :DisasterEvent ;
            rdfs:label "Major"@en ;
            skos:definition "A large-scale or aggregated event spanning days that may encompass multiple locations and related incidents." .


###  https://sakuna.ph/Municipality
:Municipality rdf:type owl:Class ;
              rdfs:subClassOf :Location ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :isPartOf ;
                                owl:someValuesFrom :Province
                              ] ;
              rdfs:label "Municipality"@en ;
              skos:definition "Administrative Level 3" .


###  https://sakuna.ph/PowerDisruption
:PowerDisruption rdf:type owl:Class ;
                 rdfs:subClassOf :Impact ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :affectedDescription ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :disruptionType ;
                                   owl:someValuesFrom xsd:string
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :interruptionDateTime ;
                                   owl:someValuesFrom xsd:dateTime
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :restorationDateTime ;
                                   owl:someValuesFrom xsd:dateTime
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :serviceProvider ;
                                   owl:someValuesFrom xsd:string
                                 ] ;
                 rdfs:label "Power Disruption"@en ;
                 skos:definition "Represents power disruptions." .


###  https://sakuna.ph/PreemptiveEvacuation
:PreemptiveEvacuation rdf:type owl:Class ;
                      rdfs:subClassOf :Preparedness ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :evacuationCenters ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :evacuationPlan ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :preemptFamilies ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :preemptFemales ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :preemptMales ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :preemptPersons ;
                                        owl:someValuesFrom xsd:int
                                      ] ;
                      rdfs:label "Preemptive Evacuation"@en ;
                      skos:definition "Represents information on evacuation centers and preemptively evacuated individuals." .


###  https://sakuna.ph/Preparedness
:Preparedness rdf:type owl:Class ;
              rdfs:label "Preparedness" ;
              skos:definition "Represents preparations done by government or non-government units before a disaster event." .


###  https://sakuna.ph/Province
:Province rdf:type owl:Class ;
          rdfs:subClassOf :Location ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isPartOf ;
                            owl:someValuesFrom :Region
                          ] ;
          rdfs:label "Province"@en ;
          skos:definition "Administrative Level 2" .


###  https://sakuna.ph/Recovery
:Recovery rdf:type owl:Class ;
          rdfs:subClassOf :Response ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :policyChanges ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :postStructureCost ;
                            owl:someValuesFrom xsd:decimal
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :postTraining ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :srrDone ;
                            owl:someValuesFrom xsd:boolean
                          ] ;
          rdfs:label "Recovery" ;
          skos:definition "Represents civic repercussions and changes made to recover after the disaster event." .


###  https://sakuna.ph/Region
:Region rdf:type owl:Class ;
        rdfs:subClassOf :Location ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :isPartOf ;
                          owl:someValuesFrom :IslandGroup
                        ] ;
        rdfs:label "Region"@en ;
        skos:definition "Administrative Level 1" .


###  https://sakuna.ph/Rescue
:Rescue rdf:type owl:Class ;
        rdfs:subClassOf :Response ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :rescueEquipment ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :rescueUnit ;
                          owl:someValuesFrom xsd:string
                        ] ;
        rdfs:label "Rescue" ;
        skos:definition "Represents information on rescue materials prepared." .


###  https://sakuna.ph/Response
:Response rdf:type owl:Class ;
          rdfs:label "Response"@en ;
          skos:definition "Represents the responses taken to a disaster." .


###  https://sakuna.ph/RoadAndBridgesDamage
:RoadAndBridgesDamage rdf:type owl:Class ;
                      rdfs:subClassOf :Impact ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :affectedDescription ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :notPassableDateTime ;
                                        owl:someValuesFrom xsd:dateTime
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :passableDateTime ;
                                        owl:someValuesFrom xsd:dateTime
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :roadBridgeClassification ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :roadBridgeName ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :roadBridgeStatus ;
                                        owl:someValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :roadBridgeType ;
                                        owl:someValuesFrom xsd:string
                                      ] ;
                      rdfs:label "Road and Bridges Damage"@en ;
                      skos:definition "Represents land transportation disruptions." .


###  https://sakuna.ph/SeaportDisruption
:SeaportDisruption rdf:type owl:Class ;
                   rdfs:subClassOf :Impact ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :affectedDescription ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :cancellationDateTime ;
                                     owl:someValuesFrom xsd:dateTime
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :portOrTerminalName ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :portStatus ;
                                     owl:someValuesFrom xsd:string
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :resumptionDateTime ;
                                     owl:someValuesFrom xsd:dateTime
                                   ] ;
                   rdfs:label "Seaport Disruption" ;
                   skos:definition "Represents seaport disruptions." .


###  https://sakuna.ph/Source
:Source rdf:type owl:Class ;
        rdfs:subClassOf prov:Entity ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :format ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :lastUpdateDate ;
                          owl:someValuesFrom xsd:dateTime
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :obtainedDate ;
                          owl:someValuesFrom xsd:dateTime
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :reportLink ;
                          owl:someValuesFrom xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :reportName ;
                          owl:someValuesFrom xsd:string
                        ] ;
        rdfs:label "Source" ;
        skos:definition "Represents the source that provided the disaster data." .


###  https://sakuna.ph/StrandedEvent
:StrandedEvent rdf:type owl:Class ;
               rdfs:subClassOf :Impact ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :district ;
                                 owl:someValuesFrom xsd:string
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :portOrTerminalName ;
                                 owl:someValuesFrom xsd:string
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :station ;
                                 owl:someValuesFrom xsd:string
                               ] ,
