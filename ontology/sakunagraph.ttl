:PreemptiveEvacuation rdf:type owl:Class ;
                      rdfs:subClassOf :Preparedness ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :evacuationCenters ;
                                        owl:someValuesFrom xsd:integer
                                      ] ,
