                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :restorationDateTime ;
                                   owl:someValuesFrom xsd:dateTime
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :serviceProvider ;
                                   owl:someValuesFrom xsd:string
                                 ] ;
                 rdfs:label "Water (Disruption)"@en ;
                 skos:definition "Represents clean water disruptions." .


