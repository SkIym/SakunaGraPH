###  https://sakuna.ph/IslandGroup
:IslandGroup rdf:type owl:Class ;
             rdfs:subClassOf :Location ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :isPartOf ;
                               owl:someValuesFrom :Country
                             ] ;
             rdfs:label "Island Group" .


###  https://sakuna.ph/Location
:Location rdf:type owl:Class ;
          rdfs:subClassOf geo:Feature ;
          rdfs:label "Location"@en ;
          skos:definition "Represents tiered locations (administrative levels) in the Philippines." .


###  https://sakuna.ph/MajorEvent
:MajorEvent rdf:type owl:Class ;
            rdfs:subClassOf :DisasterEvent ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasRelatedIncident ;
                              owl:someValuesFrom :Incident
                            ] ;
            rdfs:label "Major"@en ;
            skos:definition "A large-scale or aggregated event spanning days that may encompass multiple locations and related incidents." .


###  https://sakuna.ph/Municipality
:Municipality rdf:type owl:Class ;
              rdfs:subClassOf :Location ,
