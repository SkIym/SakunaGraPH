#################################################################
# Preparedness and response shapes
#################################################################

sgsh:PreparednessShape a sh:NodeShape ;
    rdfs:comment "Validates shared Preparedness location, agency/LGU, and remarks properties without relying on subclass inference." ;
    sh:targetClass :Preparedness, :PreemptiveEvacuation, :Warning ;
    sh:property
        sgsh:PreparednessHasLocationPropertyShape,
        sgsh:PreparednessHasRegionPropertyShape,
        sgsh:PreparednessHasProvincePropertyShape,
        sgsh:PreparednessHasMunicipalityPropertyShape,
        sgsh:PreparednessHasBarangayPropertyShape,
        sgsh:PreparednessRemarksPropertyShape .

sgsh:PreemptiveEvacuationShape a sh:NodeShape ;
    rdfs:comment "Requires and validates evacuation-center, plan, family, sex-disaggregated, and total preemptive evacuation counts." ;
    sh:targetClass :PreemptiveEvacuation ;
    sh:property
        sgsh:PreemptiveEvacuationEvacuationCentersPropertyShape,
        sgsh:PreemptiveEvacuationEvacuationPlanPropertyShape,
        sgsh:PreemptiveEvacuationPreemptFamiliesPropertyShape,
        sgsh:PreemptiveEvacuationPreemptFemalesPropertyShape,
        sgsh:PreemptiveEvacuationPreemptMalesPropertyShape,
        sgsh:PreemptiveEvacuationPreemptPersonsPropertyShape .

sgsh:WarningShape a sh:NodeShape ;
    rdfs:comment "Validates warning announcement text, timestamp, and contributing organizations." ;
    sh:targetClass :Warning ;
    sh:property
        sgsh:WarningWarningReleasedPropertyShape,
        sgsh:WarningWarningTimeStampPropertyShape,
        sgsh:WarningContributingOrgPropertyShape .

sgsh:ResponseShape a sh:NodeShape ;
    rdfs:comment "Validates shared Response location and remarks properties without relying on subclass inference." ;
    sh:targetClass :Response, :Assistance, :DeclarationOfCalamity, :Recovery, :Rescue ;
