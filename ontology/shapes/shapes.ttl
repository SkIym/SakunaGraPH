        [ rdfs:comment "roadBridgeStatus is required by the ontology restriction and must be a string." ;
          sh:path :roadBridgeStatus ;
          sh:datatype xsd:string ],
        [ rdfs:comment "roadBridgeType is required by the ontology restriction and must be a string." ;
          sh:path :roadBridgeType ;
