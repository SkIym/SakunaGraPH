        [ rdfs:comment "serviceProvider is required by the ontology restriction and must be a string." ;
          sh:path :serviceProvider ;
          sh:datatype xsd:string ] .

sgsh:RoadAndBridgesDamageShape a sh:NodeShape ;
    rdfs:comment "Requires and validates road and bridge disruption timestamps, names, status, type, and classification." ;
    sh:targetClass :RoadAndBridgesDamage ;
    sh:property
        [ rdfs:comment "affectedDescription is required by the ontology restriction and must be a string." ;
          sh:path :affectedDescription ;
