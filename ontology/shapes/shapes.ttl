        sgsh:ResponseHasLocationPropertyShape,
        sgsh:ResponseHasRegionPropertyShape,
        sgsh:ResponseHasProvincePropertyShape,
        sgsh:ResponseHasMunicipalityPropertyShape,
        sgsh:ResponseHasBarangayPropertyShape,
        sgsh:ResponseRemarksPropertyShape .

sgsh:AssistanceShape a sh:NodeShape ;
    rdfs:comment "Validates assistance organization, contribution, item, family-assistance, and agency presence fields." ;
    sh:targetClass :Assistance ;
    sh:property
        sgsh:AssistanceContributingOrgPropertyShape,
        sgsh:AssistanceContributionAmountPropertyShape,
        sgsh:AssistanceItemCostPropertyShape,
        sgsh:AssistanceItemCostPerUnitPropertyShape,
        sgsh:AssistanceContributionTypePropertyShape,
        sgsh:AssistanceAgencyLGUsPresentPropertyShape,
        sgsh:AssistanceInternationalOrgsPresentPropertyShape,
        sgsh:AssistanceItemQuantityPropertyShape,
        sgsh:AssistanceItemTypeOrNeedsPropertyShape,
        sgsh:AssistanceItemUnitPropertyShape,
        sgsh:AssistanceNoFamiliesAssistedPropertyShape,
        sgsh:AssistanceNoFamiliesNeedingAssistancePropertyShape .

sgsh:DeclarationOfCalamityShape a sh:NodeShape ;
    rdfs:comment "Requires and validates declaration type, resolution date, and resolution number declared on DeclarationOfCalamity." ;
    sh:targetClass :DeclarationOfCalamity ;
    sh:property
        sgsh:DeclarationOfCalamityDeclarationTypePropertyShape,
        sgsh:DeclarationOfCalamityResolutionDatePropertyShape,
        sgsh:DeclarationOfCalamityResolutionNoPropertyShape .

sgsh:RecoveryShape a sh:NodeShape ;
    rdfs:comment "Requires and validates policy, post-structure cost, training, and search/rescue/retrieval fields declared on Recovery." ;
