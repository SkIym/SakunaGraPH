#################################################################
# Preparedness and response shapes
#################################################################

sgsh:PreparednessShape a sh:NodeShape ;
    rdfs:comment "Validates shared Preparedness location, agency/LGU, and remarks properties without relying on subclass inference." ;
    sh:targetClass :Preparedness, :PreemptiveEvacuation, :Warning ;
    sh:property
        [ rdfs:comment "Preparedness hasLocation values must be Location resources." ;
          sh:path :hasLocation ;
          sh:class :Location ],
        [ rdfs:comment "Preparedness hasRegion values must be Region resources." ;
          sh:path :hasRegion ;
          sh:class :Region ],
        [ rdfs:comment "Preparedness hasProvince values must be Province resources." ;
          sh:path :hasProvince ;
          sh:class :Province ],
        [ rdfs:comment "Preparedness hasMunicipality values must be Municipality resources." ;
          sh:path :hasMunicipality ;
          sh:class :Municipality ],
        [ rdfs:comment "Preparedness hasBarangay stores a barangay label according to xsd:string." ;
          sh:path :hasBarangay ;
          sh:datatype xsd:string ],
        [ rdfs:comment "Preparedness remarks follow xsd:string." ;
          sh:path :remarks ;
          sh:datatype xsd:string ] .

sgsh:PreemptiveEvacuationShape a sh:NodeShape ;
    rdfs:comment "Requires and validates evacuation-center, plan, family, sex-disaggregated, and total preemptive evacuation counts." ;
    sh:targetClass :PreemptiveEvacuation ;
    sh:property
        [ rdfs:comment "evacuationCenters is required by the ontology restriction and must be an integer literal." ;
          sh:path :evacuationCenters ;
          sh:node sgsh:IntegerLiteralShape ],
        [ rdfs:comment "evacuationPlan is required by the ontology restriction and must be a string." ;
          sh:path :evacuationPlan ;
          sh:datatype xsd:string ],
        [ rdfs:comment "preemptFamilies is required by the ontology restriction and must be an integer literal." ;
          sh:path :preemptFamilies ;
          sh:node sgsh:IntegerLiteralShape ],
        [ rdfs:comment "preemptFemales is required by the ontology restriction and must be an integer literal." ;
          sh:path :preemptFemales ;
          sh:node sgsh:IntegerLiteralShape ],
        [ rdfs:comment "preemptMales is required by the ontology restriction and must be an integer literal." ;
          sh:path :preemptMales ;
          sh:node sgsh:IntegerLiteralShape ],
        [ rdfs:comment "preemptPersons is required by the ontology restriction and must be an integer literal." ;
          sh:path :preemptPersons ;
          sh:node sgsh:IntegerLiteralShape ] .

sgsh:WarningShape a sh:NodeShape ;
    rdfs:comment "Validates warning announcement text, timestamp, and contributing organizations." ;
    sh:targetClass :Warning ;
    sh:property
        [ rdfs:comment "warningReleased follows the Warning data property range xsd:string." ;
          sh:path :warningReleased ;
          sh:datatype xsd:string ],
        [ rdfs:comment "warningTimeStamp follows the Warning data property range xsd:dateTime." ;
          sh:path :warningTimeStamp ;
          sh:datatype xsd:dateTime ],
        [ rdfs:comment "contributingOrg values on warnings must be prov:Organization resources." ;
          sh:path :contributingOrg ;
          sh:class prov:Organization ] .

sgsh:ResponseShape a sh:NodeShape ;
    rdfs:comment "Validates shared Response location and remarks properties without relying on subclass inference." ;
    sh:targetClass :Response, :Assistance, :DeclarationOfCalamity, :Recovery, :Relief, :Rescue ;
    sh:property
        [ rdfs:comment "Response hasLocation values must be Location resources." ;
          sh:path :hasLocation ;
          sh:class :Location ],
        [ rdfs:comment "Response hasRegion values must be Region resources." ;
          sh:path :hasRegion ;
          sh:class :Region ],
        [ rdfs:comment "Response hasProvince values must be Province resources." ;
          sh:path :hasProvince ;
          sh:class :Province ],
        [ rdfs:comment "Response hasMunicipality values must be Municipality resources." ;
          sh:path :hasMunicipality ;
          sh:class :Municipality ],
        [ rdfs:comment "Response hasBarangay stores a barangay label according to xsd:string." ;
          sh:path :hasBarangay ;
          sh:datatype xsd:string ],
        [ rdfs:comment "Response remarks follow xsd:string." ;
          sh:path :remarks ;
          sh:datatype xsd:string ] .

sgsh:AssistanceShape a sh:NodeShape ;
    rdfs:comment "Validates assistance organization, contribution, item, family-assistance, and agency presence fields." ;
    sh:targetClass :Assistance ;
    sh:property
        [ rdfs:comment "contributingOrg values must be prov:Organization resources." ;
          sh:path :contributingOrg ;
          sh:class prov:Organization ],
        [ rdfs:comment "contributionAmount values must be QuantityValue resources." ;
          sh:path :contributionAmount ;
          sh:class qudt:QuantityValue ],
        [ rdfs:comment "itemCost values must be QuantityValue resources." ;
          sh:path :itemCost ;
          sh:class qudt:QuantityValue ],
        [ rdfs:comment "itemCostPerUnit values must be QuantityValue resources." ;
          sh:path :itemCostPerUnit ;
          sh:class qudt:QuantityValue ],
        [ rdfs:comment "contributionType follows the Assistance data property range xsd:string." ;
          sh:path :contributionType ;
          sh:datatype xsd:string ],
        [ rdfs:comment "agencyLGUsPresent follows the Assistance or Preparedness data property range xsd:string." ;
          sh:path :agencyLGUsPresent ;
          sh:datatype xsd:string ],
        [ rdfs:comment "internationalOrgsPresent follows the Assistance data property range xsd:string." ;
          sh:path :internationalOrgsPresent ;
          sh:datatype xsd:string ],
        [ rdfs:comment "itemQuantity follows the Assistance data property range xsd:decimal." ;
          sh:path :itemQuantity ;
          sh:node sgsh:DecimalLiteralShape ],
        [ rdfs:comment "itemTypeOrNeeds follows the Assistance data property range xsd:string." ;
          sh:path :itemTypeOrNeeds ;
          sh:datatype xsd:string ],
        [ rdfs:comment "itemUnit follows the Assistance data property range xsd:string." ;
          sh:path :itemUnit ;
          sh:datatype xsd:string ],
        [ rdfs:comment "noFamiliesAssisted follows the Assistance data property range xsd:int or xsd:integer." ;
          sh:path :noFamiliesAssisted ;
          sh:node sgsh:IntegerLiteralShape ],
        [ rdfs:comment "noFamiliesNeedingAssistance follows the Assistance data property range xsd:int or xsd:integer." ;
          sh:path :noFamiliesNeedingAssistance ;
          sh:node sgsh:IntegerLiteralShape ] .

sgsh:DeclarationOfCalamityShape a sh:NodeShape ;
    rdfs:comment "Requires and validates declaration type, resolution date, and resolution number declared on DeclarationOfCalamity." ;
    sh:targetClass :DeclarationOfCalamity ;
    sh:property
        [ rdfs:comment "declarationType is required by the ontology restriction and must be a string." ;
          sh:path :declarationType ;
          sh:datatype xsd:string ],
        [ rdfs:comment "resolutionDate is required by the ontology restriction and must be xsd:dateTime." ;
          sh:path :resolutionDate ;
          sh:datatype xsd:dateTime ],
        [ rdfs:comment "resolutionNo is required by the ontology restriction and must be a string." ;
          sh:path :resolutionNo ;
          sh:datatype xsd:string ] .

sgsh:RecoveryShape a sh:NodeShape ;
    rdfs:comment "Requires and validates policy, post-structure cost, training, and search/rescue/retrieval fields declared on Recovery." ;
    sh:targetClass :Recovery ;
    sh:property
        [ rdfs:comment "policyChanges is required by the ontology restriction and must be a string." ;
          sh:path :policyChanges ;
          sh:datatype xsd:string ],
        [ rdfs:comment "postStructureCost is required by the ontology restriction and must point to a QuantityValue resource." ;
          sh:path :postStructureCost ;
          sh:class qudt:QuantityValue ],
        [ rdfs:comment "postTraining is required by the ontology restriction and must be a string." ;
          sh:path :postTraining ;
          sh:datatype xsd:string ],
        [ rdfs:comment "srrDone is required by the ontology restriction; the declared property range is xsd:string." ;
          sh:path :srrDone ;
          sh:datatype xsd:string ] .

sgsh:ReliefShape a sh:NodeShape ;
    rdfs:comment "Targets Relief resources so relief instances remain auditable even though the ontology currently has no Relief-specific properties." ;
    sh:targetClass :Relief .

sgsh:RescueShape a sh:NodeShape ;
    rdfs:comment "Requires and validates rescue equipment, rescue unit, and contributing organizations declared on Rescue." ;
    sh:targetClass :Rescue ;
    sh:property
        [ rdfs:comment "rescueEquipment is required by the ontology restriction and must be a string." ;
          sh:path :rescueEquipment ;
          sh:datatype xsd:string ],
        [ rdfs:comment "rescueUnit is required by the ontology restriction and must be a string." ;
          sh:path :rescueUnit ;
          sh:datatype xsd:string ],
        [ rdfs:comment "contributingOrg values on rescue resources must be prov:Organization resources." ;
          sh:path :contributingOrg ;
          sh:class prov:Organization ] .

#################################################################
# Source, quantity, and climate-parameter shapes
#################################################################

sgsh:SourceShape a sh:NodeShape ;
    rdfs:comment "Requires and validates source metadata fields declared on Source." ;
    sh:targetClass :Source ;
    sh:property
        [ rdfs:comment "format is required by the ontology restriction and must be a string." ;
          sh:path :format ;
          sh:minCount 1 ;
          sh:datatype xsd:string ],
        [ rdfs:comment "lastUpdateDate is required by the ontology restriction and must be xsd:dateTime." ;
          sh:path :lastUpdateDate ;
          sh:datatype xsd:dateTime ],
        [ rdfs:comment "obtainedDate is required by the ontology restriction and must be xsd:dateTime." ;
          sh:path :obtainedDate ;
          sh:minCount 1 ;
          sh:datatype xsd:dateTime ],
        [ rdfs:comment "reportLink is required by the ontology restriction and must be a string." ;
          sh:path :reportLink ;
          sh:minCount 1 ;
          sh:datatype xsd:string ],
        [ rdfs:comment "reportName is required by the ontology restriction and must be a string." ;
          sh:path :reportName ;
          sh:minCount 1 ;
          sh:datatype xsd:string ] .

sgsh:QuantityValueShape a sh:NodeShape ;
    rdfs:comment "Targets QUDT QuantityValue resources used by monetary and amount object properties for auditability." ;
    sh:targetClass qudt:QuantityValue .

sgsh:CurrencyUnitShape a sh:NodeShape ;
    rdfs:comment "Targets QUDT CurrencyUnit resources used by amount values for auditability." ;
    sh:targetClass qudt:CurrencyUnit .

sgsh:ClimateParameterShape a sh:NodeShape ;
    rdfs:comment "Validates beAWARE ClimateParameter measurement values, units, type, location, and incident inverse links." ;
    sh:targetClass baw:ClimateParameter ;
    sh:property
        [ rdfs:comment "hasValue follows the beAWARE ClimateParameter data property range xsd:float." ;
          sh:path baw:hasValue ;
          sh:datatype xsd:float ],
        [ rdfs:comment "hasUnit follows the beAWARE ClimateParameter data property range xsd:string." ;
          sh:path baw:hasUnit ;
          sh:datatype xsd:string ],
        [ rdfs:comment "isOfClimateParameterType values must be beAWARE ClimateParameterType resources." ;
          sh:path baw:isOfClimateParameterType ;
          sh:class baw:ClimateParameterType ],
        [ rdfs:comment "hasMeasurementLocation values must be beAWARE Location resources." ;
          sh:path baw:hasMeasurementLocation ;
          sh:class baw:Location ],
        [ rdfs:comment "isClimateParameterOfIncident values must be beAWARE Incident resources." ;
          sh:path baw:isClimateParameterOfIncident ;
          sh:class baw:Incident ] .

sgsh:ClimateParameterTypeShape a sh:NodeShape ;
    rdfs:comment "Targets beAWARE ClimateParameterType resources such as Temperature, Magnitude, WindSpeed, FloodDepth, and WaveHeight." ;
    sh:targetClass baw:ClimateParameterType .

sgsh:GeoFeatureShape a sh:NodeShape ;
    rdfs:comment "Targets GeoSPARQL Feature resources so geographic features can be audited alongside SakunaGraPH Location resources." ;
    sh:targetClass geo:Feature .
