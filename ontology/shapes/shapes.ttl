        [ rdfs:comment "numberInfraDamaged is required by the ontology restriction and must be an integer literal." ;
          sh:path :numberInfraDamaged ;
          sh:node sgsh:IntegerLiteralShape ] .

sgsh:PowerDisruptionShape a sh:NodeShape ;
    rdfs:comment "Requires and validates power disruption details declared on PowerDisruption." ;
    sh:targetClass :PowerDisruption ;
    sh:property
        [ rdfs:comment "affectedDescription is required by the ontology restriction and must be a string." ;
          sh:path :affectedDescription ;
          sh:datatype xsd:string ],
        [ rdfs:comment "disruptionType is required by the ontology restriction and must be a string." ;
          sh:path :disruptionType ;
