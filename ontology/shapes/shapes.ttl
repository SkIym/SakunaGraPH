sgsh:PreparednessHasLocationPropertyShape a sh:PropertyShape ;
    rdfs:comment "Preparedness hasLocation values must be concrete Location subclass resources." ;
    sh:path :hasLocation ;
    sh:or (
        [ sh:class :Country ]
        [ sh:class :IslandGroup ]
        [ sh:class :Region ]
        [ sh:class :Province ]
        [ sh:class :Municipality ]
        [ sh:class :City ]
        [ sh:class :SubMunicipality ]
        [ sh:class :Barangay ]
    ) .

