#################################################################
# Core event and classification shapes
#################################################################

sgsh:DisasterEventShape a sh:NodeShape ;
    rdfs:comment "Validates common DisasterEvent fields and event-to-impact, preparedness, response, location, disaster type, and climate-parameter links." ;
    sh:targetClass :DisasterEvent, :Incident, :MajorEvent, baw:NaturalDisaster ;
    sh:property
        sgsh:DisasterEventEventNamePropertyShape,
        sgsh:DisasterEventStartDatePropertyShape,
        sgsh:DisasterEventEndDatePropertyShape,
        sgsh:DisasterEventEntryDatePropertyShape,
        sgsh:DisasterEventLastUpdateDatePropertyShape,
        sgsh:DisasterEventReferencePropertyShape,
        sgsh:DisasterEventRemarksPropertyShape,
        sgsh:DisasterEventHasDisasterTypePropertyShape,
        sgsh:DisasterEventHasDisasterSubtypePropertyShape,
        sgsh:DisasterEventBawIsOfDisasterTypePropertyShape,
        sgsh:DisasterEventHasImpactPropertyShape,
        sgsh:DisasterEventHasAffectedPopulationPropertyShape,
        sgsh:DisasterEventHasAgricultureDamagePropertyShape,
        sgsh:DisasterEventHasAirportDisruptionPropertyShape,
        sgsh:DisasterEventHasCasualtiesPropertyShape,
        sgsh:DisasterEventHasClassSuspensionPropertyShape,
        sgsh:DisasterEventHasCommunicationLineDisruptionPropertyShape,
        sgsh:DisasterEventHasDamageGeneralPropertyShape,
        sgsh:DisasterEventHasHousingDamagePropertyShape,
        sgsh:DisasterEventHasInfrastructureDamagePropertyShape,
        sgsh:DisasterEventHasPowerDisruptionPropertyShape,
        sgsh:DisasterEventHasRoadAndBridgesDamagePropertyShape,
        sgsh:DisasterEventHasSeaportDisruptionPropertyShape,
        sgsh:DisasterEventHasStrandedEventPropertyShape,
        sgsh:DisasterEventHasWaterDisruptionPropertyShape,
        sgsh:DisasterEventHasWorkSuspensionPropertyShape,
        sgsh:DisasterEventHasPreparednessPropertyShape,
        sgsh:DisasterEventHasPreemptiveEvacuationPropertyShape,
        sgsh:DisasterEventHasWarningPropertyShape,
        sgsh:DisasterEventHasResponsePropertyShape,
        sgsh:DisasterEventHasAssistancePropertyShape,
        sgsh:DisasterEventHasDeclarationOfCalamityPropertyShape,
        sgsh:DisasterEventHasRecoveryPropertyShape,
        sgsh:DisasterEventHasRescuePropertyShape,
        sgsh:DisasterEventHasLocationPropertyShape,
        sgsh:DisasterEventHasRegionPropertyShape,
        sgsh:DisasterEventHasProvincePropertyShape,
        sgsh:DisasterEventHasMunicipalityPropertyShape,
        sgsh:DisasterEventHasBarangayPropertyShape,
        sgsh:DisasterEventBawHasClimateParameterMeasurementPropertyShape,
        sgsh:DisasterEventBawHasDisasterStartPropertyShape,
        sgsh:DisasterEventBawHasDisasterEndPropertyShape,
        sgsh:DisasterEventBawHasDisasterLocationPropertyShape .

sgsh:IncidentShape a sh:NodeShape ;
    rdfs:comment "Validates Incident-specific fields and its link to a parent MajorEvent." ;
    sh:targetClass :Incident, baw:Incident ;
    sh:property
        sgsh:IncidentIncidentDescriptionPropertyShape,
        sgsh:IncidentIncidentActionsTakenPropertyShape,
        sgsh:IncidentIsRelatedToPropertyShape,
        sgsh:IncidentIncidentDerivedFromPropertyShape,
        sgsh:IncidentBawHasIncidentClimateParameterPropertyShape,
        sgsh:IncidentBawHasIncidentLocationPropertyShape .

sgsh:MajorEventShape a sh:NodeShape ;
    rdfs:comment "Validates MajorEvent-specific links to related incidents." ;
    sh:targetClass :MajorEvent ;
    sh:property
        sgsh:MajorEventHasRelatedIncidentPropertyShape .

sgsh:DisasterTypeShape a sh:NodeShape ;
    rdfs:comment "Validates DisasterType SKOS classification metadata used for EM-DAT-style hazard concepts." ;
    sh:targetClass :DisasterType ;
    sh:property
        sgsh:DisasterTypeSkosBroaderPropertyShape,
        sgsh:DisasterTypeSkosInSchemePropertyShape,
        sgsh:DisasterTypeSkosDefinitionPropertyShape .

sgsh:DisasterTypeSchemeShape a sh:NodeShape ;
    rdfs:comment "Targets the DisasterTypeScheme node so the scheme can be audited separately from DisasterType concepts." ;
    sh:targetNode :DisasterTypeScheme .

#################################################################
# Impact shapes
#################################################################

sgsh:ImpactShape a sh:NodeShape ;
    rdfs:comment "Validates shared Impact location and remarks properties for all impact subclasses without relying on inference." ;
    sh:targetClass :Impact, baw:Impact, :AffectedPopulation, :AgricultureDamage, :AirportDisruption, :Casualties, :ClassSuspension, :CommunicationLineDisruption, :DamageGeneral, :FlightDisruption, :HousingDamage, :InfrastructureDamage, :PowerDisruption, :RoadAndBridgesDamage, :SeaportDisruption, :StrandedEvent, :WaterDisruption, :WorkSuspension ;
    sh:property
        sgsh:ImpactHasLocationPropertyShape,
        sgsh:ImpactHasRegionPropertyShape,
        sgsh:ImpactHasProvincePropertyShape,
        sgsh:ImpactHasMunicipalityPropertyShape,
        sgsh:ImpactHasBarangayPropertyShape,
        sgsh:ImpactRemarksPropertyShape .

sgsh:AffectedPopulationShape a sh:NodeShape ;
    rdfs:comment "Requires and validates affected and displaced population counts declared on AffectedPopulation." ;
    sh:targetClass :AffectedPopulation ;
    sh:property
