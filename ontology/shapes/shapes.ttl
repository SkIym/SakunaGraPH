        [ rdfs:comment "portStatus is required by the ontology restriction and must be a string." ;
          sh:path :portStatus ;
          sh:datatype xsd:string ],
        [ rdfs:comment "resumptionDateTime is required by the ontology restriction and must be xsd:dateTime." ;
          sh:path :resumptionDateTime ;
          sh:datatype xsd:dateTime ] .

sgsh:StrandedEventShape a sh:NodeShape ;
    rdfs:comment "Requires and validates stranded transport location descriptors and stranded passenger/cargo/vessel counts." ;
    sh:targetClass :StrandedEvent ;
    sh:property
        [ rdfs:comment "district is required by the ontology restriction and must be a string." ;
