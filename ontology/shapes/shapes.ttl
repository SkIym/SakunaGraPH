        sgsh:AffectedPopulationAffectedFamiliesPropertyShape,
        sgsh:AffectedPopulationAffectedPersonsPropertyShape,
        sgsh:AffectedPopulationDisplacedFamiliesPropertyShape,
        sgsh:AffectedPopulationDisplacedPersonsPropertyShape .

sgsh:AgricultureDamageShape a sh:NodeShape ;
