    rdfs:comment "cpi follows the DamageGeneral data property range xsd:decimal." ;
    sh:path :cpi ;
    sh:node sgsh:DecimalLiteralShape .

sgsh:FlightDisruptionAirlinePropertyShape a sh:PropertyShape ;
    rdfs:comment "airline follows the FlightDisruption data property range xsd:string." ;
