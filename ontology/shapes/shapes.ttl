        sgsh:AgricultureDamageAgriDamageUnitPropertyShape,
        sgsh:AgricultureDamageFarmerFisherfolkAffectedPropertyShape,
        sgsh:AgricultureDamagePartiallyDamagedCropAreaPropertyShape,
        sgsh:AgricultureDamagePartiallyDamagedInfrastructurePropertyShape,
        sgsh:AgricultureDamageProductionLossCostPropertyShape,
        sgsh:AgricultureDamageProductionLossVolumePropertyShape,
        sgsh:AgricultureDamageTotallyDamagedCropAreaPropertyShape,
        sgsh:AgricultureDamageTotallyDamagedInfrastructurePropertyShape .

sgsh:AirportDisruptionShape a sh:NodeShape ;
