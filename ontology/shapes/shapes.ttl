        [ rdfs:comment "notPassableDateTime is required by the ontology restriction and must be xsd:dateTime." ;
          sh:path :notPassableDateTime ;
          sh:datatype xsd:dateTime ],
        [ rdfs:comment "passableDateTime is required by the ontology restriction and must be xsd:dateTime." ;
          sh:path :passableDateTime ;
